@using SortVivo.Models

<div class="recursion-tree-container">
    @if (!string.IsNullOrEmpty(Label))
    {
        <div class="recursion-tree-label">@Label</div>
    }

    @if (Snapshot != null && Snapshot.Nodes.Length > 0)
    {
        // レイアウトキャッシュをクリアして再計算
        _nodeXPositions.Clear();
        _subtreeWidthCache.Clear();
        _nodeDepths.Clear();

        // X座標と走査深さを計算
        var treeRoot = Snapshot.Nodes.FirstOrDefault(n => n.ParentId == -1);
        if (treeRoot != null) CalculateTreeLayout(treeRoot);

        // 実際のコンテンツ幅から viewW を決定（固定 1200px フロアを廃止しコンテンツに合わせる）
        double viewW;
        if (_nodeXPositions.Count > 0)
        {
            double treeMinX = _nodeXPositions
                .Select(kv => kv.Value - GetActualNodeWidth(Snapshot.Nodes.First(n => n.Id == kv.Key)) / 2)
                .Min();
            double treeMaxX = _nodeXPositions
                .Select(kv => kv.Value + GetActualNodeWidth(Snapshot.Nodes.First(n => n.Id == kv.Key)) / 2)
                .Max();
            double treeW = treeMaxX - treeMinX;
            double padding = 40 * HorizScale;
            viewW = Math.Max(200 * HorizScale, treeW + padding * 2);
            double centerOffset = padding - treeMinX;
            foreach (var key in _nodeXPositions.Keys.ToList())
                _nodeXPositions[key] += centerOffset;
        }
        else
        {
            viewW = 400 * HorizScale;
        }

        // CalculateTreeLayout で記録した走査深さで viewH を正確に計算する
        var maxDepth = _nodeDepths.Count > 0 ? _nodeDepths.Values.Max() : Snapshot.Nodes.Max(n => n.Depth);

        // DNF ポインタ（lt/i/gt）がある場合はノード高さを拡張する
        var hasDnfPointers = Snapshot.Nodes.Any(n => n.Lt.HasValue || n.I.HasValue || n.Gt.HasValue);
        _levelHeight = hasDnfPointers ? 200 : 180;
        var nodeHeight = hasDnfPointers ? 130 : 110;
        var viewH = Math.Max(200, (maxDepth + 1) * (int)_levelHeight + 100);
        var marbleSize = (int)Math.Round(28 * HorizScale);
        var marbleSpacing = Math.Max(marbleSize * 2 + 4, (int)Math.Round(60 * HorizScale));
        var marbleFont = (int)Math.Round(20.0 * HorizScale);

        <svg class="recursion-tree-svg" viewBox="@($"0 0 {viewW} {viewH}")" preserveAspectRatio="xMidYMid meet" style="max-width: @((int)viewW)px">
            <defs>
                <filter id="@_glowFilterId" x="-50%" y="-50%" width="200%" height="200%">
                    <feGaussianBlur stdDeviation="3" result="blur" />
                    <feMerge>
                        <feMergeNode in="blur" />
                        <feMergeNode in="SourceGraphic" />
                    </feMerge>
                </filter>
            </defs>

            @* Edges (drawn first, behind nodes) *@
            @for (int edgeIdx = 0; edgeIdx < Snapshot.Nodes.Length; edgeIdx++)
            {
                var node = Snapshot.Nodes[edgeIdx];
                if (node.ParentId >= 0)
                {
                    var parent = Snapshot.Nodes.FirstOrDefault(n => n.Id == node.ParentId);
                    if (parent != null)
                    {
                        // レイアウトツリーに含まれないノードへのエッジは非表示。
                        // IsChildOfCompletedNode は 1 階層上の確認のみなので、孫ノードが孤立するケースをカバーできない。
                        if (!_nodeXPositions.ContainsKey(node.Id) || !_nodeXPositions.ContainsKey(parent.Id)) continue;
                        var (px, py) = GetNodePosition(parent, maxDepth, viewW);
                        var (cx, cy) = GetNodePosition(node, maxDepth, viewW);

                        bool edgeHighlighted = node.State == RecursionNodeState.Active ||
                                             node.State == RecursionNodeState.Merging;
                        var edgeStroke = edgeHighlighted
                            ? GetNodeStateColor(node.State)
                            : "rgba(255,255,255,0.2)";
                        var edgeWidth = edgeHighlighted ? "2.5" : "1.5";

                        <line x1="@(px)" y1="@(py + nodeHeight/2)"
                              x2="@(cx)" y2="@(cy - nodeHeight/2)"
                              stroke="@edgeStroke"
                              stroke-width="@edgeWidth" />
                    }
                }
            }

            @* Nodes *@
            @for (int nodeIdx = 0; nodeIdx < Snapshot.Nodes.Length; nodeIdx++)
            {
                var node = Snapshot.Nodes[nodeIdx];

                // レイアウトツリーに含まれないノードは非表示。
                // 孤立ノード（祖先が Completed で親の深さまで IsChildOfCompleted が伝播されないケース）も除外される。
                if (!_nodeXPositions.ContainsKey(node.Id)) continue;

                var (nx, ny) = GetNodePosition(node, maxDepth, viewW);

                // ノード幅を要素数に応じて動的に調整（GetActualNodeWidthと統一）
                var nodeWidth = (int)GetActualNodeWidth(node);

                bool isActive = node.Id == Snapshot.ActiveNodeId;
                var borderColor = GetNodeStateColor(node.State);

                // Pending は薄く表示（まだ処理されていない）
                var nodeStyle = node.State == RecursionNodeState.Pending
                    ? "opacity: 0.4;"
                    : "opacity: 1.0;";

                // Precompute text variables (outside SVG text tags to avoid Razor syntax conflict)
                var rangeText = $"[{node.Start}..{node.End})";
                var rangeY = ny - nodeHeight/2 + 18;
                var pivotText = node.PivotValue.HasValue ? $"pivot={node.PivotValue}" : "";
                var pivotY = ny + nodeHeight / 2 - 14;
                var checkX = nx + nodeWidth/2 - 8;
                var checkY = ny - nodeHeight/2 + 15;

                <g class="recursion-node" style="@nodeStyle">
                    @* ノード枠 *@
                    @if (isActive)
                    {
                        <rect x="@(nx - nodeWidth/2 - 4)" y="@(ny - nodeHeight/2 - 4)"
                              width="@(nodeWidth + 8)" height="@(nodeHeight + 8)"
                              rx="8" ry="8"
                              fill="none"
                              stroke="@borderColor"
                              stroke-width="3"
                              opacity="0.6"
                              filter="@($"url(#{_glowFilterId})")" />
                    }

                    <rect x="@(nx - nodeWidth/2)" y="@(ny - nodeHeight/2)"
                          width="@nodeWidth" height="@nodeHeight"
                          rx="6" ry="6"
                          fill="rgba(30, 30, 30, 0.9)"
                          stroke="@borderColor"
                          stroke-width="@(isActive ? "2.5" : "1.5")" />

                    @* 範囲ラベル（@ifの外なのでtext要素を直接使用可） *@
                    <text x="@nx" y="@rangeY" text-anchor="middle" dominant-baseline="central" fill="rgba(156, 163, 175, 1)" font-size="11" font-weight="600">@rangeText</text>

                    @* 値のマーブル表示 *@
                    @if (node.Values.Length > 0)
                    {
                        var marbleStartX = nx - (node.Values.Length * marbleSpacing) / 2 + marbleSpacing / 2;
                        var marbleY = ny + 2;

                        @for (int i = 0; i < node.Values.Length; i++)
                        {
                            var value = node.Values[i];
                            var mx = marbleStartX + i * marbleSpacing;
                            var marbleColor = GetValueColor(value);
                            var isPivot = node.PivotValue.HasValue && value == node.PivotValue.Value;
                            var my = marbleY + 1;

                            <circle cx="@mx" cy="@marbleY" r="@marbleSize" fill="@marbleColor" stroke="@(isPivot ? "#FBBF24" : "rgba(255,255,255,0.2)")" stroke-width="@(isPivot ? "2.5" : "1.5")" />
                            @(new MarkupString($"<text x=\"{mx:F2}\" y=\"{my:F2}\" text-anchor=\"middle\" dominant-baseline=\"central\" fill=\"white\" font-size=\"{marbleFont}\" font-weight=\"700\">{value}</text>"))
                        }

                        @* DNF ポインタラベル（lt/i/gt）: QuickSort 3-way のみ *@
                        @if (node.Lt.HasValue || node.I.HasValue || node.Gt.HasValue)
                        {
                            var ptrBaseY = marbleY + marbleSize + 9;
                            @for (int pi = 0; pi < node.Values.Length; pi++)
                            {
                                var absIdx = node.Start + pi;
                                var pmx = marbleStartX + pi * marbleSpacing;
                                // 同一マーブルに複数ラベルが重なる場合は縦にスタックする
                                var ptrRow = 0;
                                if (node.Lt.HasValue && absIdx == node.Lt.Value)
                                {
                                    @(new MarkupString($"<text x=\"{pmx:F2}\" y=\"{ptrBaseY + ptrRow * 10:F2}\" text-anchor=\"middle\" dominant-baseline=\"central\" fill=\"#06B6D4\" font-size=\"9\" font-weight=\"700\">lt</text>"))
                                    ptrRow++;
                                }
                                if (node.I.HasValue && absIdx == node.I.Value)
                                {
                                    @(new MarkupString($"<text x=\"{pmx:F2}\" y=\"{ptrBaseY + ptrRow * 10:F2}\" text-anchor=\"middle\" dominant-baseline=\"central\" fill=\"#FBBF24\" font-size=\"9\" font-weight=\"700\">i</text>"))
                                    ptrRow++;
                                }
                                if (node.Gt.HasValue && absIdx == node.Gt.Value)
                                {
                                    @(new MarkupString($"<text x=\"{pmx:F2}\" y=\"{ptrBaseY + ptrRow * 10:F2}\" text-anchor=\"middle\" dominant-baseline=\"central\" fill=\"#F97316\" font-size=\"9\" font-weight=\"700\">gt</text>"))
                                }
                            }
                        }
                    }

                    @* ピボット表示（Quicksort）：@ifの内側なのでMarkupString使用 *@
                    @if (node.PivotValue.HasValue)
                    {
                        @(new MarkupString($"<text x=\"{nx:F2}\" y=\"{pivotY:F2}\" text-anchor=\"middle\" dominant-baseline=\"central\" fill=\"#FBBF24\" font-size=\"10\" font-weight=\"600\">{pivotText}</text>"))
                    }

                    @* リーフ種別ラベル（InsertionSort / HeapSort 委譲）*@
                    @if (node.State == RecursionNodeState.InsertionSortLeaf)
                    {
                        @(new MarkupString($"<text x=\"{nx:F2}\" y=\"{pivotY:F2}\" text-anchor=\"middle\" dominant-baseline=\"central\" fill=\"#06B6D4\" font-size=\"10\" font-weight=\"600\">↓ InsertionSort</text>"))
                    }
                    @if (node.State == RecursionNodeState.HeapSortLeaf)
                    {
                        @(new MarkupString($"<text x=\"{nx:F2}\" y=\"{pivotY:F2}\" text-anchor=\"middle\" dominant-baseline=\"central\" fill=\"#F97316\" font-size=\"10\" font-weight=\"600\">↓ HeapSort</text>"))
                    }

                    @* 状態インジケーター：@ifの内側なのでMarkupString使用 *@
                    @if (node.State == RecursionNodeState.Completed)
                    {
                        @(new MarkupString($"<text x=\"{checkX:F2}\" y=\"{checkY:F2}\" text-anchor=\"end\" dominant-baseline=\"central\" fill=\"#10B981\" font-size=\"14\">✓</text>"))
                    }
                </g>
            }
        </svg>
    }
    else
    {
        <div class="recursion-tree-empty">No recursion data</div>
    }
</div>

@code {
    /// <summary>再帰ツリーのスナップショット</summary>
    [Parameter] public RecursionSnapshot? Snapshot { get; set; }

    /// <summary>配列内の最大値（HSLグラデーション計算に使用）</summary>
    [Parameter] public int MaxValue { get; set; } = 9;

    /// <summary>現在のステップインデックス（アニメーション再トリガー用）</summary>
    [Parameter] public int StepIndex { get; set; } = -1;

    /// <summary>水平方向のスケール係数（1.0 = 通常、0.5 = 半分。タブレット・スマホ向けに間隔を圧縮する際に使用）</summary>
    [Parameter] public double HorizScale { get; set; } = 1.0;

    /// <summary>行ラベル</summary>
    [Parameter] public string Label { get; set; } = string.Empty;

    private readonly string _glowFilterId = $"glow-{Guid.NewGuid().ToString("N")[..8]}";

    // レイアウト計算用キャッシュ
    private readonly Dictionary<int, double> _nodeXPositions = new();
    private readonly Dictionary<int, double> _subtreeWidthCache = new();
    private readonly Dictionary<int, int> _nodeDepths = new();
    // DNF ポインタ表示時に levelHeight / nodeHeight を拡張するフラグ（レンダリング前に設定）
    private double _levelHeight = 180;

    /// <summary>
    /// ノードの実際の描画幅を計算する（要素数に応じた動的幅）。
    /// </summary>
    private double GetActualNodeWidth(RecursionNode node)
        => Math.Max(200, (node.End - node.Start) * 60 + 60) * HorizScale;

    /// <summary>
    /// ノードの位置を計算（x, y）。
    /// 親子関係を考慮したツリーレイアウト：各ノードは子ノードの中央に配置される。
    /// </summary>
    private (double x, double y) GetNodePosition(RecursionNode node, int maxDepth, double viewW)
    {
        // _nodeDepths は CalculateTreeLayout の走査で記録した実際の深さ。
        // node.Depth は ReattachChildren の伝播漏れで誤った値になる場合があるため使用しない。
        int depth = _nodeDepths.GetValueOrDefault(node.Id, node.Depth);
        double y = 60 + depth * _levelHeight;

        double x = _nodeXPositions.GetValueOrDefault(node.Id, viewW / 2);
        return (x, y);
    }

    /// <summary>
    /// ノードのサブツリー描画幅を返す（メモ化付き）。
    /// 自身の描画幅と全可視子ノードのサブツリー幅の合計の大きい方を採用する。
    /// これにより親ノードが子ノードより広い場合でも兄弟ノードと重ならない。
    /// </summary>
    private double GetSubtreeWidth(RecursionNode node)
    {
        if (_subtreeWidthCache.TryGetValue(node.Id, out var cached)) return cached;

        double gap = 40 * HorizScale;
        var visibleChildren = Snapshot!.Nodes
            .Where(n => n.ParentId == node.Id && !IsChildOfCompletedNode(n))
            .OrderBy(n => n.Start)
            .ToList();

        double width;
        if (visibleChildren.Count == 0)
        {
            width = GetActualNodeWidth(node);
        }
        else
        {
            double totalChildWidth = visibleChildren.Sum(c => GetSubtreeWidth(c)) + (visibleChildren.Count - 1) * gap;
            width = Math.Max(GetActualNodeWidth(node), totalChildWidth);
        }

        _subtreeWidthCache[node.Id] = width;
        return width;
    }

    /// <summary>
    /// ツリー全体のX座標をトップダウンで計算する。
    /// サブツリー幅を基にノードを配置するため、親ノードが子ノードより幅広い場合でも
    /// 同じ深さの兄弟ノードが重ならない。
    /// </summary>
    private void CalculateTreeLayout(RecursionNode node, double left = 0, int depth = 0)
    {
        _nodeDepths[node.Id] = depth;
        double subtreeWidth = GetSubtreeWidth(node);
        _nodeXPositions[node.Id] = left + subtreeWidth / 2;

        double gap = 40 * HorizScale;
        var visibleChildren = Snapshot!.Nodes
            .Where(n => n.ParentId == node.Id && !IsChildOfCompletedNode(n))
            .OrderBy(n => n.Start)
            .ToList();

        if (visibleChildren.Count == 0) return;

        double totalChildrenWidth = visibleChildren.Sum(c => GetSubtreeWidth(c)) + (visibleChildren.Count - 1) * gap;
        double childLeft = left + (subtreeWidth - totalChildrenWidth) / 2;

        foreach (var child in visibleChildren)
        {
            CalculateTreeLayout(child, childLeft, depth + 1);
            childLeft += GetSubtreeWidth(child) + gap;
        }
    }

    /// <summary>
    /// 値に基づいてマーブルの色を生成（HSLグラデーション）。
    /// </summary>
    private string GetValueColor(int value)
    {
        double hue = MaxValue > 1 ? (value - 1) * 360.0 / (MaxValue - 1) : 0;
        return $"hsl({hue:F0}, 70%, 50%)";
    }

    /// <summary>
    /// ノードの状態に応じた色を返す。
    /// </summary>
    private string GetNodeStateColor(RecursionNodeState state) => state switch
    {
        RecursionNodeState.Pending          => "rgba(107, 114, 128, 0.5)",  // グレー
        RecursionNodeState.Active           => "#A855F7",                     // 紫（分割中）
        RecursionNodeState.Merging          => "#F59E0B",                     // 橙（マージ中）
        RecursionNodeState.Completed        => "#10B981",                     // 緑（完了）
        RecursionNodeState.InsertionSortLeaf => "#06B6D4",                    // シアン（InsertionSort 委譲）
        RecursionNodeState.HeapSortLeaf      => "#F97316",                    // オレンジ（HeapSort 委譲）
        _ => "rgba(255,255,255,0.2)"
    };

    /// <summary>
    /// ノードの親が完了済み（Completed）かどうかを判定する。
    /// マージ完了後、子ノード（マージ元）を薄く表示するために使用。
    /// </summary>
    private bool IsChildOfCompletedNode(RecursionNode node)
    {
        if (node.ParentId < 0 || Snapshot == null) return false;

        var parent = Snapshot.Nodes.FirstOrDefault(n => n.Id == node.ParentId);
        if (parent == null) return false;

        bool isCompleted = parent.State == RecursionNodeState.Completed;

        // デバッグ（ブラウザのコンソールで確認可能）
        // Console.WriteLine($"Node [{node.Start}..{node.End}) parent [{parent.Start}..{parent.End}) isCompleted={isCompleted}");

        return isCompleted;
    }
}
