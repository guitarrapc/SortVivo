@using SortVivo.Models
@using SortVivo.Services
@inject AlgorithmRegistry AlgorithmRegistry
@inject IJSRuntime JS
@inject LocalizationService L

@if (IsOpen || _isClosing)
{
    @* 背景暗転: クリックで閉じる *@
    <div class="settings-backdrop @(_isClosing ? "settings-backdrop--leaving" : "")" @onclick="HandleClose"></div>

    @* モーダル本体: クリックが背景に伝播しないよう stopPropagation *@
    <div class="settings-modal @(_isClosing ? "settings-modal--leaving" : "")" @onclick:stopPropagation>

        @* ── ヘッダー ── *@
        <div class="settings-modal__header">
            <span class="settings-modal__title">@L["settings.title"]</span>
            <button class="settings-modal__close" @onclick="HandleClose" title="@L["common.close"]">✕</button>
        </div>

        @* ── スクロール可能なボディ ── *@
        <div class="settings-modal__body">

            @* ────────────────────────────────────
               ⚙️ General
               ──────────────────────────────────── *@
            <section class="settings-section">
                <h3 class="settings-section__title">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-gear" viewBox="0 0 16 16">
                        <path d="M8 4.754a3.246 3.246 0 1 0 0 6.492 3.246 3.246 0 0 0 0-6.492M5.754 8a2.246 2.246 0 1 1 4.492 0 2.246 2.246 0 0 1-4.492 0" />
                        <path d="M9.796 1.343c-.527-1.79-3.065-1.79-3.592 0l-.094.319a.873.873 0 0 1-1.255.52l-.292-.16c-1.64-.892-3.433.902-2.54 2.541l.159.292a.873.873 0 0 1-.52 1.255l-.319.094c-1.79.527-1.79 3.065 0 3.592l.319.094a.873.873 0 0 1 .52 1.255l-.16.292c-.892 1.64.901 3.434 2.541 2.54l.292-.159a.873.873 0 0 1 1.255.52l.094.319c.527 1.79 3.065 1.79 3.592 0l.094-.319a.873.873 0 0 1 1.255-.52l.292.16c1.64.893 3.434-.902 2.54-2.541l-.159-.292a.873.873 0 0 1 .52-1.255l.319-.094c1.79-.527 1.79-3.065 0-3.592l-.319-.094a.873.873 0 0 1-.52-1.255l.16-.292c.893-1.64-.902-3.433-2.541-2.54l-.292.159a.873.873 0 0 1-1.255-.52zm-2.633.283c.246-.835 1.428-.835 1.674 0l.094.319a1.873 1.873 0 0 0 2.693 1.115l.291-.16c.764-.415 1.6.42 1.184 1.185l-.159.292a1.873 1.873 0 0 0 1.116 2.692l.318.094c.835.246.835 1.428 0 1.674l-.319.094a1.873 1.873 0 0 0-1.115 2.693l.16.291c.415.764-.42 1.6-1.185 1.184l-.291-.159a1.873 1.873 0 0 0-2.693 1.116l-.094.318c-.246.835-1.428.835-1.674 0l-.094-.319a1.873 1.873 0 0 0-2.692-1.115l-.292.16c-.764.415-1.6-.42-1.184-1.185l.159-.291A1.873 1.873 0 0 0 1.945 8.93l-.319-.094c-.835-.246-.835-1.428 0-1.674l.319-.094A1.873 1.873 0 0 0 3.06 4.377l-.16-.292c-.415-.764.42-1.6 1.185-1.184l.292.159a1.873 1.873 0 0 0 2.692-1.115z" />
                    </svg>
                    @L["settings.general"]
                </h3>
                <div class="settings-section__body">

                    <div class="settings-row">
                        <span class="settings-label">@L["settings.language"]</span>
                        <select class="settings-select"
                                value="@L.CurrentLanguage"
                                @onchange="e => ChangeLanguageAsync(e.Value!.ToString()!)">
                            @foreach (var lang in LocalizationService.SupportedLanguages)
                            {
                                <option value="@lang">@LocalizationService.GetFlagEmoji(lang) @LocalizationService.GetDisplayName(lang)</option>
                            }
                        </select>
                    </div>

                    <div class="settings-row">
                        <span class="settings-label">
                            @L["settings.renderer"]
                        </span>
                        <div class="settings-segment settings-segment--fit">
                            <button class="settings-segment__btn @(!RenderSettings.UseWebGL ? "settings-segment__btn--active" : "")"
                                    @onclick="() => RenderSettings.UseWebGL = false">
                                @L["settings.canvas2d"]
                            </button>
                            <button class="settings-segment__btn @(RenderSettings.UseWebGL ? "settings-segment__btn--active" : "")"
                                    @onclick="() => RenderSettings.UseWebGL = true">
                                @L["settings.webgl"]
                            </button>
                        </div>
                    </div>
                    <div class="settings-row settings-row--hint">
                        <span class="settings-hint">@L["settings.webglHint"]</span>
                    </div>

                    <div class="settings-row">
                        <span class="settings-label">@L["settings.autoReset"]</span>
                        <label class="toggle-switch">
                            <input type="checkbox" @bind="Playback.AutoReset" />
                            <span class="toggle-slider"></span>
                        </label>
                    </div>

                    <div class="settings-row">
                        <span class="settings-label">@L["settings.instantMode"] <span class="settings-hint-inline">@L["settings.noAnimation"]</span></span>
                        <label class="toggle-switch">
                            <input type="checkbox" @bind="Playback.InstantMode" />
                            <span class="toggle-slider"></span>
                        </label>
                    </div>

                </div>
            </section>

            @* ────────────────────────────────────
               🔊 Sound
               ──────────────────────────────────── *@
            <section class="settings-section">
                <h3 class="settings-section__title">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
                        <path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"></path>
                    </svg>
                    @L["settings.sound"]
                </h3>
                <div class="settings-section__body">

                    <div class="settings-row settings-row--vertical">
                        <div class="settings-row__inline">
                            <span class="settings-label">@L["settings.volume"]</span>
                            <span class="settings-value">@((int)(Playback.SoundVolume * 100))%</span>
                        </div>
                        <input type="range" min="0" max="1" step="0.05"
                               @bind="Playback.SoundVolume"
                               @bind:event="oninput"
                               @bind:after="HandleVolumeChanged"
                               class="settings-slider"
                               style="@RangeTrackStyle(Playback.SoundVolume, 0, 1)" />
                    </div>

                    <div class="settings-row">
                        <span class="settings-label">@L["settings.soundType"]</span>
                        <select class="settings-select"
                                value="@Playback.SoundType"
                                @onchange="e => HandleSoundTypeChanged(e.Value!.ToString()!)">
                            <option value="sine">@L["settings.soundTypeSine"]</option>
                            <option value="poko">@L["settings.soundTypePoko"]</option>
                            <option value="cutePop">@L["settings.soundTypeCutePop"]</option>
                        </select>
                    </div>

                </div>
            </section>

            @* ────────────────────────────────────
               🔧 Advanced
               ──────────────────────────────────── *@
            <section class="settings-section">
                <h3 class="settings-section__title">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-tools" viewBox="0 0 16 16">
                        <path d="M1 0 0 1l2.2 3.081a1 1 0 0 0 .815.419h.07a1 1 0 0 1 .708.293l2.675 2.675-2.617 2.654A3.003 3.003 0 0 0 0 13a3 3 0 1 0 5.878-.851l2.654-2.617.968.968-.305.914a1 1 0 0 0 .242 1.023l3.27 3.27a.997.997 0 0 0 1.414 0l1.586-1.586a.997.997 0 0 0 0-1.414l-3.27-3.27a1 1 0 0 0-1.023-.242L10.5 9.5l-.96-.96 2.68-2.643A3.005 3.005 0 0 0 16 3q0-.405-.102-.777l-2.14 2.141L12 4l-.364-1.757L13.777.102a3 3 0 0 0-3.675 3.68L7.462 6.46 4.793 3.793a1 1 0 0 1-.293-.707v-.071a1 1 0 0 0-.419-.814zm9.646 10.646a.5.5 0 0 1 .708 0l2.914 2.915a.5.5 0 0 1-.707.707l-2.915-2.914a.5.5 0 0 1 0-.708M3 11l.471.242.529.026.287.445.445.287.026.529L5 13l-.242.471-.026.529-.445.287-.287.445-.529.026L3 15l-.471-.242L2 14.732l-.287-.445L1.268 14l-.026-.529L1 13l.242-.471.026-.529.445-.287.287-.445.529-.026z" />
                    </svg>
                    @L["settings.advanced"]
                </h3>
                <div class="settings-section__body">

                    <div class="settings-row">
                        <span class="settings-label">@L["settings.scrollOnGenerate"] <span class="settings-hint-inline">@L["settings.tabletMobile"]</span></span>
                        <label class="toggle-switch">
                            <input type="checkbox" @bind="RenderSettings.ScrollOnGenerate" />
                            <span class="toggle-slider"></span>
                        </label>
                    </div>

                    <div class="settings-row">
                        <span class="settings-label">@L["settings.autoRecommendedSize"]</span>
                        <label class="toggle-switch">
                            <input type="checkbox"
                                   checked="@AutoSwitchToRecommendedSize"
                                   @onchange="e => AutoSwitchToRecommendedSizeChanged.InvokeAsync((bool)e.Value!)" />
                            <span class="toggle-slider"></span>
                        </label>
                    </div>

                    <div class="settings-row">
                        <span class="settings-label">@L["settings.debugLog"]</span>
                        <label class="toggle-switch">
                            <input type="checkbox"
                                   @bind="DebugSettings.IsEnabled"
                                   @bind:after="HandleDebugToggleChanged" />
                            <span class="toggle-slider"></span>
                        </label>
                    </div>

                </div>
            </section>

            @* ────────────────────────────────────
               🔒 About
               ──────────────────────────────────── *@
            <section class="settings-section">
                <h3 class="settings-section__title">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-lock" viewBox="0 0 16 16">
                        <path fill-rule="evenodd" d="M8 0a4 4 0 0 1 4 4v2.05a2.5 2.5 0 0 1 2 2.45v5a2.5 2.5 0 0 1-2.5 2.5h-7A2.5 2.5 0 0 1 2 13.5v-5a2.5 2.5 0 0 1 2-2.45V4a4 4 0 0 1 4-4M4.5 7A1.5 1.5 0 0 0 3 8.5v5A1.5 1.5 0 0 0 4.5 15h7a1.5 1.5 0 0 0 1.5-1.5v-5A1.5 1.5 0 0 0 11.5 7zM8 1a3 3 0 0 0-3 3v2h6V4a3 3 0 0 0-3-3" />
                    </svg>
                    @L["settings.about"]
                </h3>
                <div class="settings-section__body">

                    <div class="about-content">
                        <div class="about-item">
                            <h4 class="about-item__title">@L["settings.aboutBrowserBased"]</h4>
                            <p class="about-item__text">
                                @L["settings.aboutBrowserBasedText"]
                            </p>
                        </div>

                        <div class="about-item">
                            <h4 class="about-item__title">@L["settings.aboutPrivacy"]</h4>
                            <p class="about-item__text">
                                @L["settings.aboutPrivacyText"]
                            </p>
                        </div>
                    </div>

                </div>
            </section>

        </div>
    </div>
}

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    [Parameter, EditorRequired] public PlaybackService Playback { get; set; } = default!;
    [Parameter, EditorRequired] public RenderSettings RenderSettings { get; set; } = default!;
    [Parameter, EditorRequired] public DebugSettings DebugSettings { get; set; } = default!;
    [Parameter, EditorRequired] public ComparisonModeService ComparisonMode { get; set; } = default!;

    private bool _isClosing = false;

    [Parameter] public bool AutoSwitchToRecommendedSize { get; set; }
    [Parameter] public EventCallback<bool> AutoSwitchToRecommendedSizeChanged { get; set; }

    private async Task HandleClose()
    {
        if (_isClosing) return;
        _isClosing = true;
        await Task.Delay(200);
        _isClosing = false;
        await OnClose.InvokeAsync();
    }

    private async Task ChangeLanguageAsync(string lang)
    {
        await L.SetLanguageAsync(lang, JS);
    }

    private async Task HandleDebugToggleChanged()
    {
        await JS.InvokeVoidAsync("debugHelper.setDebugMode", DebugSettings.IsEnabled);
    }

    private async Task HandleSoundTypeChanged(string soundType)
    {
        Playback.SoundType = soundType;
        await ComparisonMode.SetSoundTypeForAllAsync(soundType);
    }

    private void HandleVolumeChanged()
    {
        ComparisonMode.SetSoundVolumeForAll(Playback.SoundVolume);
    }

    private static string RangeTrackStyle(double value, double min, double max)
    {
        var pct = (value - min) / (max - min) * 100;
        return $"background:linear-gradient(to right,var(--color-accent) 0%,var(--color-accent) {pct:F1}%,#4A4A4A {pct:F1}%,#4A4A4A 100%)";
    }
}
