@using SortVivo.Models

<div class="heap-tree-container">
    @if (!string.IsNullOrEmpty(Label))
    {
        <div class="heap-tree-label">@Label</div>
    }

    @if (HeapBoundary > 0)
    {
        var depth = GetTreeDepth();
        var viewW = 800;
        var viewH = Math.Max(120, (depth + 1) * 90);
        var nodeR = 21;

        <svg class="heap-tree-svg" viewBox="@($"0 0 {viewW} {viewH}")" preserveAspectRatio="xMidYMid meet">
            <defs>
                <filter id="@_glowFilterId" x="-50%" y="-50%" width="200%" height="200%">
                    <feGaussianBlur stdDeviation="3" result="blur" />
                    <feMerge>
                        <feMergeNode in="blur" />
                        <feMergeNode in="SourceGraphic" />
                    </feMerge>
                </filter>
            </defs>

            @*─ Edges (drawn first, behind nodes)─ *@
            @for (int i = 0; i < HeapBoundary; i++)
            {
                var (px, py) = GetNodePosition(i, depth, viewW, viewH, nodeR);

                for (int c = 0; c < BranchingFactor; c++)
                {
                    int child = BranchingFactor * i + 1 + c;
                    if (child < HeapBoundary)
                    {
                        var (cx, cy) = GetNodePosition(child, depth, viewW, viewH, nodeR);
                        bool edgeHighlighted = HighlightSet.Contains(i) && HighlightSet.Contains(child);
                        bool distinguished = IsDistinguishedEdge(i, child);
                        var edgeStroke = edgeHighlighted
                            ? GetHighlightColor()
                            : distinguished ? "rgba(255,255,255,0.30)" : "rgba(255,255,255,0.12)";
                        var edgeWidth = edgeHighlighted ? "2.5" : "1.5";
                        var edgeDash = !distinguished ? "5 3" : "none";
                        <line x1="@px" y1="@py" x2="@cx" y2="@cy"
                              stroke="@edgeStroke"
                              stroke-width="@edgeWidth"
                              stroke-dasharray="@edgeDash" />
                    }
                }
            }

            @*─ Nodes─ *@
            @for (int i = 0; i < HeapBoundary; i++)
            {
                var idx = i;
                var value = Values[idx];
                var (nx, ny) = GetNodePosition(idx, depth, viewW, viewH, nodeR);
                bool highlighted = HighlightSet.Contains(idx);
                string bgColor = GetValueColor(value);

                <g class="@(highlighted ? "heap-node heap-node--highlighted" : "heap-node")">
                    @if (highlighted)
                    {
                        <circle cx="@nx" cy="@ny" r="@(nodeR + 5)"
                                fill="none"
                                stroke="@GetHighlightColor()"
                                stroke-width="2.5"
                                opacity="0.5"
                                filter="@($"url(#{_glowFilterId})")" />
                    }
                    <circle cx="@nx" cy="@ny" r="@nodeR"
                            fill="@bgColor"
                            stroke="@(highlighted ? GetHighlightColor() : "rgba(255,255,255,0.15)")"
                            stroke-width="@(highlighted ? "3" : "1.5")" />
                    <text x="@nx" y="@(ny + 1)" text-anchor="middle" dominant-baseline="central"
                          fill="white" font-size="14" font-weight="700">@value</text>
                </g>
            }
        </svg>

        @*─ Sorted region indicator─ *@
        @if (HeapBoundary < Values.Length)
        {
            <div class="heap-sorted-region">
                <span class="heap-sorted-label">Sorted:</span>
                <div class="heap-sorted-values">
                    @for (int i = HeapBoundary; i < Values.Length; i++)
                    {
                        var value = Values[i];
                        <span class="heap-sorted-marble" style="background: @GetValueColor(value);">@value</span>
                    }
                </div>
            </div>
        }
    }
    else
    {
        <div class="heap-tree-empty">No heap data</div>
    }
</div>

@code {
    /// <summary>表示する配列の値（ArraySnapshot 全体）</summary>
    [Parameter] public int[] Values { get; set; } = [];

    /// <summary>ヒープ境界。0 ≤ i &lt; HeapBoundary がヒープ内ノード</summary>
    [Parameter] public int HeapBoundary { get; set; }

    /// <summary>ハイライト対象のインデックス</summary>
    [Parameter] public int[] HighlightIndices { get; set; } = [];

    /// <summary>ハイライトの種類</summary>
    [Parameter] public OperationType HighlightType { get; set; }

    /// <summary>行ラベル</summary>
    [Parameter] public string Label { get; set; } = string.Empty;

    /// <summary>配列内の最大値（HSLグラデーション計算に使用）</summary>
    [Parameter] public int MaxValue { get; set; } = 9;

    /// <summary>ヒープの分岐数（2 = 二分ヒープ、3 = 三分ヒープ）</summary>
    [Parameter] public int BranchingFactor { get; set; } = 2;

    /// <summary>
    /// WeakHeap の reverse bit 配列（r[i] = true → 右子 2i+1 が distinguished child）。
    /// null の場合は全辺を solid 表示（通常の二分 / 三分ヒープ）。
    /// </summary>
    [Parameter] public bool[]? ReverseBits { get; set; }

    /// <summary>現在のステップインデックス（アニメーション再トリガー用）</summary>
    [Parameter] public int StepIndex { get; set; } = -1;

    private readonly string _glowFilterId = $"glow-{Guid.NewGuid().ToString("N")[..8]}";

    private HashSet<int> HighlightSet => [.. HighlightIndices];

    /// <summary>
    /// 辺 (parent → child) が distinguished edge かどうかを返す。
    /// ReverseBits が null（通常ヒープ）の場合は常に true（全辺 solid）。
    /// WeakHeap の場合: distinguished child = 2*parent + r[parent]。
    /// </summary>
    private bool IsDistinguishedEdge(int parent, int child)
    {
        if (ReverseBits == null) return true;
        bool rParent = parent < ReverseBits.Length && ReverseBits[parent];
        int distinguishedChild = 2 * parent + (rParent ? 1 : 0);
        return child == distinguishedChild;
    }

    /// <summary>ヒープの深さ（0-indexed）を計算。n-ary ヒープに対応。</summary>
    private int GetTreeDepth()
    {
        if (HeapBoundary <= 0) return 0;
        int b = BranchingFactor;
        int d = 0;
        long count = 1; // nodes at or above this level
        while (count < HeapBoundary)
        {
            d++;
            count = count * b + 1; // total nodes in complete tree of depth d: (b^(d+1)-1)/(b-1)
        }
        return d;
    }

    /// <summary>ノードの SVG 座標を計算。n-ary ヒープに対応。</summary>
    private (double X, double Y) GetNodePosition(int index, int depth, int viewW, int viewH, int nodeR)
    {
        int b = BranchingFactor;

        // Calculate level: the level containing index i in a b-ary heap
        // Level 0 has 1 node, level 1 has b nodes, level 2 has b^2 nodes, etc.
        // Total nodes in levels 0..L-1 = (b^L - 1) / (b - 1)
        int level = 0;
        long levelStart = 0;
        long levelSize = 1;
        while (levelStart + levelSize <= index)
        {
            levelStart += levelSize;
            levelSize *= b;
            level++;
        }
        long posInLevel = index - levelStart;

        // Horizontal: evenly distribute nodes at each level
        double x = (posInLevel + 0.5) * viewW / levelSize;

        // Vertical: evenly distribute levels with padding
        double topPad = nodeR + 8;
        double bottomPad = nodeR + 8;
        double availH = viewH - topPad - bottomPad;
        double y = depth == 0
            ? viewH / 2.0
            : topPad + level * (availH / depth);

        return (x, y);
    }

    /// <summary>ハイライト色を取得</summary>
    private string GetHighlightColor() => HighlightType switch
    {
        OperationType.Compare => "#A855F7",
        OperationType.Swap => "#EF4444",
        OperationType.IndexRead => "#FBBF24",
        OperationType.IndexWrite => "#F97316",
        OperationType.RangeCopy => "#F97316",
        _ => "#A855F7"
    };

    /// <summary>値に応じた HSL カラーを計算（マーブルと同じ）</summary>
    private string GetValueColor(int value)
    {
        if (MaxValue <= 1) return "hsl(210, 75%, 42%)";
        var ratio = (double)(value - 1) / (MaxValue - 1);
        var hue = (int)(210 * (1.0 - ratio));
        return $"hsl({hue}, 75%, 42%)";
    }
}
