@using SortVivo.Models
@using SortVivo.Services
@inject LocalizationService L

<div class="play-control-bar">
    <div class="play-control-buttons">
        <button class="play-control-btn @(IsPlaying ? "btn-pause" : "btn-play")"
                @onclick="OnTogglePlayPause"
                disabled="@PlayDisabled"
                title="@(IsPlaying ? L["playback.pause"] : L["playback.play"])">
            @if (IsPlaying)
            {
                <svg viewBox="0 0 24 24" fill="currentColor">
                    <rect x="6" y="4" width="4" height="16"></rect>
                    <rect x="14" y="4" width="4" height="16"></rect>
                </svg>
            }
            else
            {
                <svg viewBox="0 0 24 24" fill="currentColor">
                    <polygon points="5 3 19 12 5 21 5 3"></polygon>
                </svg>
            }
        </button>

        <button class="play-control-btn btn-stop"
                @onclick="OnStop"
                disabled="@StopDisabled"
                title="@L["playback.stop"]">
            <svg viewBox="0 0 24 24" fill="currentColor">
                <rect x="5" y="5" width="14" height="14"></rect>
            </svg>
        </button>

        <button class="play-control-btn btn-clear"
                @onclick="OnClearAll"
                disabled="@ClearAllDisabled"
                title="@L["playback.clearAll"]">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="3 6 5 6 21 6"></polyline>
                <path d="M19 6l-1 14H6L5 6"></path>
                <path d="M10 11v6"></path>
                <path d="M14 11v6"></path>
                <path d="M9 6V4h6v2"></path>
            </svg>
        </button>

        <button class="play-control-btn @(SoundEnabled ? "btn-sound-on" : "btn-sound-off")"
                @onclick="OnToggleSound"
                disabled="@SoundDisabled"
                title="@(SoundDisabled ? L["playback.soundNotAvailable"] : SoundEnabled ? L["playback.soundOn"] : L["playback.soundOff"])">
            @if (SoundEnabled)
            {
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
                    <path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"></path>
                </svg>
            }
            else
            {
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
                    <line x1="23" y1="9" x2="17" y2="15"></line>
                    <line x1="17" y1="9" x2="23" y2="15"></line>
                </svg>
            }
        </button>

        <button class="play-control-btn @(IsRecording ? "btn-record-active" : "btn-record")"
                @onclick="OnToggleRecord"
                disabled="@RecordDisabled"
                title="@(IsRecording ? L["playback.recordStop"] : L["playback.record"])">
            @if (IsRecording)
            {
                <svg viewBox="0 0 24 24" fill="currentColor">
                    <rect x="6" y="6" width="12" height="12" rx="2"></rect>
                </svg>
            }
            else
            {
                <svg viewBox="0 0 24 24" fill="currentColor">
                    <circle cx="12" cy="12" r="8"></circle>
                </svg>
            }
        </button>

        <select class="record-resolution-select"
                value="@RecordingResolution"
                @onchange="HandleResolutionChange"
                disabled="@(RecordDisabled || IsRecording)"
                title="@L["playback.resolution"]">
            <option value="1080">1080p</option>
            <option value="720">720p</option>
            <option value="480">480p</option>
        </select>
    </div>

    <div class="play-control-info">
        @if (ArraySize > 0)
        {
            <span class="play-control-array-size">n=@ArraySize</span>
        }
        <span class="play-control-status">@StatusText</span>
    </div>
</div>

@code {
    [Parameter]
    public bool IsPlaying { get; set; }

    [Parameter]
    public bool PlayDisabled { get; set; }

    [Parameter]
    public bool StopDisabled { get; set; }

    [Parameter]
    public bool SoundEnabled { get; set; }

    [Parameter]
    public bool SoundDisabled { get; set; }

    [Parameter]
    public required string StatusText { get; set; }

    [Parameter]
    public int ArraySize { get; set; }

    [Parameter]
    public bool ClearAllDisabled { get; set; }

    [Parameter]
    public EventCallback OnTogglePlayPause { get; set; }

    [Parameter]
    public EventCallback OnStop { get; set; }

    [Parameter]
    public EventCallback OnToggleSound { get; set; }

    [Parameter]
    public EventCallback OnClearAll { get; set; }

    [Parameter]
    public bool IsRecording { get; set; }

    [Parameter]
    public bool RecordDisabled { get; set; }

    [Parameter]
    public EventCallback OnToggleRecord { get; set; }

    [Parameter]
    public int RecordingResolution { get; set; } = 720;

    [Parameter]
    public EventCallback<int> RecordingResolutionChanged { get; set; }

    private bool _lastIsPlaying;
    private bool _lastSoundEnabled;
    private bool _lastPlayDisabled;
    private bool _lastStopDisabled;
    private bool _lastClearAllDisabled;
    private bool _lastIsRecording;
    private bool _lastRecordDisabled;
    private int _lastRecordingResolution;
    private string _lastStatusText = "";
    private int _lastArraySize;

    protected override bool ShouldRender()
    {
        var changed = _lastIsPlaying != IsPlaying
                   || _lastSoundEnabled != SoundEnabled
                   || _lastPlayDisabled != PlayDisabled
                   || _lastStopDisabled != StopDisabled
                   || _lastClearAllDisabled != ClearAllDisabled
                   || _lastStatusText != StatusText
                   || _lastArraySize != ArraySize
                   || _lastIsRecording != IsRecording
                   || _lastRecordDisabled != RecordDisabled
                   || _lastRecordingResolution != RecordingResolution;

        _lastIsPlaying = IsPlaying;
        _lastSoundEnabled = SoundEnabled;
        _lastPlayDisabled = PlayDisabled;
        _lastStopDisabled = StopDisabled;
        _lastClearAllDisabled = ClearAllDisabled;
        _lastStatusText = StatusText;
        _lastArraySize = ArraySize;
        _lastIsRecording = IsRecording;
        _lastRecordDisabled = RecordDisabled;
        _lastRecordingResolution = RecordingResolution;

        return changed;
    }

    private async Task HandleResolutionChange(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var resolution))
        {
            await RecordingResolutionChanged.InvokeAsync(resolution);
        }
    }
}
