@using SortAlgorithm.VisualizationWeb.Models

<div class="marble-row-container">
    @if (!string.IsNullOrEmpty(Label))
    {
        <div class="marble-row-label">@Label</div>
    }
    <div class="marble-row">
        @for (int i = 0; i < Values.Length; i++)
        {
            var idx = i;
            var value = Values[idx];
            bool isEmpty = IsBuffer && value == 0;
            bool highlighted = HighlightSet.Contains(idx);
            string bgColor = isEmpty ? "transparent" : GetValueColor(value);
            string outlineClass = highlighted ? $"marble-outline-{HighlightType.ToString().ToLowerInvariant()}" : "";
            string marbleClass = $"marble {outlineClass}".Trim();
            <div class="marble-slot">
                <div class="@marbleClass" style="background: @bgColor;">
                    @(isEmpty ? "" : value.ToString())
                </div>
                <div class="marble-index">@idx</div>
            </div>
        }
    </div>
</div>

@code {
    /// <summary>表示する配列の値</summary>
    [Parameter] public int[] Values { get; set; } = [];

    /// <summary>ハイライト対象のインデックス</summary>
    [Parameter] public int[] HighlightIndices { get; set; } = [];

    /// <summary>ハイライトの種類（アウトライン色を決定）</summary>
    [Parameter] public OperationType HighlightType { get; set; }

    /// <summary>行ラベル（例: "メイン配列"）</summary>
    [Parameter] public string Label { get; set; } = string.Empty;

    /// <summary>バッファー配列かどうか（true の場合、値 0 を空表示にする）</summary>
    [Parameter] public bool IsBuffer { get; set; } = false;

    /// <summary>配列内の最大値（HSLグラデーション計算に使用）</summary>
    [Parameter] public int MaxValue { get; set; } = 9;

    private HashSet<int> HighlightSet => [.. HighlightIndices];

    /// <summary>
    /// 値に応じたHSLカラーを計算する。
    /// 小さい値=青(hue=210)〜大きい値=赤(hue=0) のグラデーション。
    /// 彩度・輝度を固定して見やすい色味を維持する。
    /// </summary>
    private string GetValueColor(int value)
    {
        if (MaxValue <= 1) return "hsl(210, 75%, 42%)";
        // hue: 210(青) → 0(赤) で値の大小を直感的に表現
        var ratio = (double)(value - 1) / (MaxValue - 1);
        var hue = (int)(210 * (1.0 - ratio));
        return $"hsl({hue}, 75%, 42%)";
    }
}
