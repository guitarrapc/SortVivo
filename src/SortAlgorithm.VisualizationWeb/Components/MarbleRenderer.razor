@using SortAlgorithm.VisualizationWeb.Models

<div class="marble-row-container">
    @if (!string.IsNullOrEmpty(Label))
    {
        <div class="marble-row-label">@Label</div>
    }
    <div class="marble-row-content">
        <div class="marble-arrow-area">
            @if (HighlightType == OperationType.Swap && HighlightIndices.Length == 2)
            {
                var (li, ri) = GetSortedPair();
                var unit = 100;
                var viewW = Values.Length * unit;
                var viewH = 48;
                var leftX = li * unit + unit / 2;
                var rightX = ri * unit + unit / 2;
                var midX = (leftX + rightX) / 2;
                var startY = viewH - 2;
                var ctrlY1 = 6;
                var ctrlY2 = 22;

                <svg class="marble-swap-arrows" viewBox="@($"0 0 {viewW} {viewH}")" preserveAspectRatio="xMidYMid meet">
                    <defs>
                        <marker id="@_arrowMarkerId" markerWidth="10" markerHeight="7"
                                refX="9" refY="3.5" orient="auto">
                            <polygon points="0 0, 10 3.5, 0 7" fill="#EF4444" />
                        </marker>
                    </defs>
                    @* Higher arc: left → right *@
                    <path d="@($"M {leftX},{startY} Q {midX},{ctrlY1} {rightX},{startY}")"
                          stroke="#EF4444" stroke-width="2.5" fill="none" stroke-linecap="round"
                          marker-end="@($"url(#{_arrowMarkerId})")" opacity="0.85" />
                    @* Lower arc: right → left *@
                    <path d="@($"M {rightX},{startY} Q {midX},{ctrlY2} {leftX},{startY}")"
                          stroke="#EF4444" stroke-width="2.5" fill="none" stroke-linecap="round"
                          marker-end="@($"url(#{_arrowMarkerId})")" opacity="0.85" />
                </svg>
            }
            else if (HighlightType == OperationType.Compare && HighlightIndices.Length == 2 && CompareResult.HasValue)
            {
                var (li, ri) = GetSortedPair();
                var unit = 100;
                var viewW = Values.Length * unit;
                var viewH = 48;
                var leftX = li * unit + unit / 2;
                var rightX = ri * unit + unit / 2;
                var midX = (leftX + rightX) / 2;
                // HighlightIndices[0] が元の Index1。左に来たら向きそのまま、右に来たら反転
                var displayResult = HighlightIndices[0] <= HighlightIndices[1]
                    ? CompareResult.Value : -CompareResult.Value;
                var symbol = displayResult > 0 ? ">" : displayResult < 0 ? "<" : "=";

                <svg class="marble-compare-symbol" viewBox="@($"0 0 {viewW} {viewH}")" preserveAspectRatio="xMidYMid meet">
                    <text x="@midX" y="@(viewH - 4)" text-anchor="middle" font-size="36"
                          font-weight="bold" fill="#A855F7" opacity="0.9">@symbol</text>
                </svg>
            }
        </div>
        <div class="marble-row">
            @for (int i = 0; i < Values.Length; i++)
            {
                var idx = i;
                var value = Values[idx];
                bool isEmpty = IsBuffer && value == 0;
                bool highlighted = HighlightSet.Contains(idx);
                string bgColor = isEmpty ? "transparent" : GetValueColor(value);
                string outlineClass = highlighted ? $"marble-outline-{HighlightType.ToString().ToLowerInvariant()}" : "";
                string marbleClass = $"marble {outlineClass}".Trim();
                bool isSwapTarget = HighlightType == OperationType.Swap
                    && HighlightIndices.Length == 2 && highlighted;
                string slotClass = isSwapTarget ? "marble-slot marble-swapping" : "marble-slot";
                string slotStyle = "";
                if (isSwapTarget)
                {
                    int otherIdx = HighlightIndices[0] == idx ? HighlightIndices[1] : HighlightIndices[0];
                    slotStyle = $"--slide-offset: {otherIdx - idx}";
                }
                <div @key="@(isSwapTarget ? (object)$"s{StepIndex}-{idx}" : idx)"
                     class="@slotClass" style="@slotStyle">
                    <div class="@marbleClass" style="background: @bgColor;">
                        @(isEmpty ? "" : value.ToString())
                    </div>
                    <div class="marble-index">@idx</div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    /// <summary>表示する配列の値</summary>
    [Parameter] public int[] Values { get; set; } = [];

    /// <summary>ハイライト対象のインデックス</summary>
    [Parameter] public int[] HighlightIndices { get; set; } = [];

    /// <summary>ハイライトの種類（アウトライン色を決定）</summary>
    [Parameter] public OperationType HighlightType { get; set; }

    /// <summary>行ラベル（例: "メイン配列"）</summary>
    [Parameter] public string Label { get; set; } = string.Empty;

    /// <summary>バッファー配列かどうか（true の場合、値 0 を空表示にする）</summary>
    [Parameter] public bool IsBuffer { get; set; } = false;

    /// <summary>配列内の最大値（HSLグラデーション計算に使用）</summary>
    [Parameter] public int MaxValue { get; set; } = 9;

    /// <summary>Compare 操作の比較結果（正: Index1 > Index2、負: Index1 &lt; Index2、null: Compare 以外）</summary>
    [Parameter] public int? CompareResult { get; set; }

    /// <summary>現在のステップインデックス（Swap アニメーション再トリガー用）</summary>
    [Parameter] public int StepIndex { get; set; } = -1;

    private readonly string _arrowMarkerId = $"ah-{Guid.NewGuid().ToString("N")[..8]}";

    private HashSet<int> HighlightSet => [.. HighlightIndices];

    /// <summary>ハイライトインデックスを昇順ペアで返す</summary>
    private (int Left, int Right) GetSortedPair()
    {
        var a = HighlightIndices[0];
        var b = HighlightIndices[1];
        return a < b ? (a, b) : (b, a);
    }

    /// <summary>
    /// 値に応じたHSLカラーを計算する。
    /// 小さい値=青(hue=210)〜大きい値=赤(hue=0) のグラデーション。
    /// 彩度・輝度を固定して見やすい色味を維持する。
    /// </summary>
    private string GetValueColor(int value)
    {
        if (MaxValue <= 1) return "hsl(210, 75%, 42%)";
        // hue: 210(青) → 0(赤) で値の大小を直感的に表現
        var ratio = (double)(value - 1) / (MaxValue - 1);
        var hue = (int)(210 * (1.0 - ratio));
        return $"hsl({hue}, 75%, 42%)";
    }
}
