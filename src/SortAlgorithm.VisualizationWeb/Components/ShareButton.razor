                        <path fill-rule="evenodd" clip-rule="evenodd" d="M12.9201 9.18844C12.5828 9.01471 12.2277 8.88817 11.8644 8.80774C11.4262 8.71076 10.9763 8.68113 10.531 8.71983C10.0392 8.76256 9.55347 8.88791 9.09595 9.09607C8.63086 9.30771 8.19494 9.60417 7.81233 9.98678L4.28426 13.5149C2.57191 15.2272 2.57191 18.0035 4.28426 19.7159C5.99663 21.4282 8.77289 21.4282 10.4853 19.7159L13.9611 16.2401C13.0783 16.3837 12.1667 16.3082 11.3145 16.0136L9.07831 18.2499C8.14717 19.181 6.60709 19.1971 5.69204 18.2502C4.80327 17.3305 4.81284 15.8592 5.72073 14.9513L9.24881 11.4233C9.39403 11.2781 9.55369 11.156 9.72318 11.0567C10.0384 10.8721 10.3877 10.7675 10.7418 10.742C11.0826 10.7173 11.4275 10.7664 11.7508 10.8891C12.0521 11.0034 12.3346 11.181 12.5769 11.4233C12.6172 11.4636 12.6558 11.5051 12.6926 11.5476C13.0345 11.9427 13.6177 12.016 14.035 11.7016C14.054 11.6873 14.0729 11.673 14.0917 11.6587C14.5379 11.319 14.6147 10.6706 14.2508 10.2439C14.1757 10.1558 14.0966 10.07 14.0133 9.98678C13.6834 9.65687 13.3138 9.39123 12.9201 9.18844Z" fill="currentColor"></path>
                    </svg>
                </span>
                <span class="share-option__label">@L["share.copyLink"]</span>
            </button>
            <button class="share-option" role="menuitem" @onclick="ShareToX" tabindex="0">
                <span class="share-option__icon">
                    <svg fill="currentColor" viewBox="0 0 24 24" height="1em" width="1em" xmlns="http://www.w3.org/2000/svg">
