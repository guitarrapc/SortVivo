                    </svg>
                </span>
                <span class="share-option__label">@L["share.shareToX"]</span>
            </button>
            <button class="share-option" role="menuitem" @onclick="ShareToThreads" tabindex="0">
                <span class="share-option__icon">
                    <svg fill="currentColor" viewBox="0 0 24 24" height="1em" width="1em" xmlns="http://www.w3.org/2000/svg">
                        <path d="M12.1403 21H12.1349C9.41597 20.982 7.32577 20.0964 5.92076 18.3684C4.67246 16.8294 4.02736 14.6892 4.00549 12.0072V11.9946C4.02736 9.3108 4.67246 7.1724 5.92258 5.6334C7.32577 3.9036 9.41779 3.018 12.1349 3H12.1403H12.1458C14.2306 3.0144 15.9745 3.5436 17.3285 4.5732C18.6023 5.5416 19.4989 6.9204 19.9927 8.6736L18.4438 9.1002C17.6055 6.1302 15.4843 4.6128 12.1385 4.5894C9.92987 4.6056 8.2588 5.2914 7.17269 6.627C6.15766 7.878 5.63283 9.6852 5.61278 12C5.63283 14.3148 6.15766 16.122 7.17451 17.373C8.26062 18.7104 9.93169 19.3962 12.1403 19.4106C14.1321 19.3962 15.4497 18.9372 16.5449 17.877C17.795 16.6674 17.7731 15.1824 17.3722 14.2788C17.1372 13.746 16.7089 13.3032 16.1312 12.9666C15.9854 13.98 15.6593 14.8008 15.1563 15.42C14.4839 16.2462 13.5308 16.698 12.3244 16.7628C11.4114 16.8114 10.5312 16.599 9.84969 16.1616C9.0424 15.645 8.57041 14.8566 8.51939 13.9386C8.47019 13.0458 8.82918 12.225 9.52896 11.6274C10.1977 11.0568 11.1381 10.722 12.2497 10.659C13.0679 10.614 13.8351 10.65 14.5422 10.7652C14.4474 10.209 14.2579 9.7662 13.9736 9.4476C13.5836 9.0084 12.9804 8.7852 12.1823 8.7798C12.175 8.7798 12.1677 8.7798 12.1604 8.7798C11.5189 8.7798 10.6479 8.9544 10.0939 9.7698L8.75994 8.886C9.50344 7.7952 10.7098 7.194 12.1604 7.194C12.1713 7.194 12.1823 7.194 12.1932 7.194C14.6187 7.2084 16.0638 8.6754 16.2078 11.235C16.2898 11.2692 16.3718 11.3052 16.452 11.3412C17.5836 11.8668 18.411 12.6624 18.8465 13.6434C19.4515 15.0096 19.508 17.2362 17.6711 19.0128C16.2661 20.37 14.5622 20.9838 12.1458 21H12.1403ZM12.9021 12.2322C12.718 12.2322 12.5321 12.2376 12.3408 12.2484C10.9467 12.3258 10.0775 12.9576 10.1267 13.8558C10.1777 14.7972 11.2292 15.2346 12.2406 15.1806C13.17 15.132 14.38 14.7738 14.5841 12.3978C14.0702 12.288 13.5071 12.2322 12.9021 12.2322Z" fill="currentColor"></path>
                    </svg>
                </span>
                <span class="share-option__label">@L["share.shareToThreads"]</span>
            </button>
            <button class="share-option" role="menuitem" @onclick="ShareToReddit" tabindex="0">
                <span class="share-option__icon">
                    <svg fill="currentColor" viewBox="0 0 24 24" height="1em" width="1em" xmlns="http://www.w3.org/2000/svg">
                        <path d="M14.238 15.348c.085.084.085.221 0 .306-.465.462-1.194.687-2.231.687l-.008-.002-.008.002c-1.036 0-1.766-.225-2.231-.688-.085-.084-.085-.221 0-.305.084-.084.222-.084.307 0 .379.377 1.008.561 1.924.561l.008.002.008-.002c.915 0 1.544-.184 1.924-.561.085-.084.223-.084.307 0zm-3.44-2.418c0-.507-.414-.919-.922-.919-.509 0-.923.412-.923.919 0 .506.414.918.923.918.508.001.922-.411.922-.918zm13.202-.93c0 6.627-5.373 12-12 12s-12-5.373-12-12 5.373-12 12-12 12 5.373 12 12zm-5-.129c0-.851-.695-1.543-1.55-1.543-.417 0-.795.167-1.074.435-1.056-.695-2.485-1.137-4.066-1.194l.865-2.724 2.343.549-.003.034c0 .696.569 1.262 1.268 1.262.699 0 1.267-.566 1.267-1.262s-.568-1.262-1.267-1.262c-.537 0-.994.335-1.179.804l-2.525-.592c-.11-.027-.223.037-.257.145l-.965 3.038c-1.656.02-3.155.466-4.258 1.181-.277-.255-.644-.415-1.05-.415-.854.001-1.549.693-1.549 1.544 0 .566.311 1.056.768 1.325-.03.164-.05.331-.05.5 0 2.281 2.805 4.137 6.253 4.137s6.253-1.856 6.253-4.137c0-.16-.017-.317-.044-.472.486-.261.82-.766.82-1.353zm-4.872.141c-.509 0-.922.412-.922.919 0 .506.414.918.922.918s.922-.412.922-.918c0-.507-.413-.919-.922-.919z"/>
                    </svg>
                </span>
                <span class="share-option__label">@L["share.shareToReddit"]</span>
            </button>
        </div>
    }
</div>

@code {
    private bool _isOpen = false;
    private DotNetObjectReference<ShareButton>? _dotNetRef;

    protected override void OnInitialized()
    {
        _dotNetRef = DotNetObjectReference.Create(this);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _dotNetRef != null)
        {
            await JS.InvokeVoidAsync("popoverHelper.register", "share-button-container", _dotNetRef);
        }
    }

    private void TogglePopover()
    {
        _isOpen = !_isOpen;
    }

    [JSInvokable]
    public void OnClickOutside()
    {
        if (_isOpen)
        {
            _isOpen = false;
            InvokeAsync(StateHasChanged);
        }
    }

    [JSInvokable]
    public void OnEscapeKey()
    {
        if (_isOpen)
        {
            _isOpen = false;
            InvokeAsync(StateHasChanged);
        }
    }

    private async Task CopyLink()
    {
        try
        {
            var url = NavigationManager.Uri;
            var success = await JS.InvokeAsync<bool>("shareHelper.copyToClipboard", url);
            
            if (success)
            {
                // TODO: Show toast notification
                Console.WriteLine(L["share.copySuccess"]);
            }
            else
            {
                Console.WriteLine(L["share.copyFailed"]);
            }
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Copy failed: {ex.Message}");
        }
        finally
        {
            _isOpen = false;
        }
    }

    private async Task ShareToX()
    {
        try
        {
            var url = NavigationManager.Uri;
            var text = L["share.defaultText"];
            var shareUrl = $"https://x.com/intent/tweet?text={Uri.EscapeDataString(text)}&url={Uri.EscapeDataString(url)}";
            
            await JS.InvokeVoidAsync("shareHelper.openShareWindow", shareUrl, "Share to X", 600, 400);
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"Share to X failed: {ex.Message}");
        }
        finally
        {
            _isOpen = false;
        }
    }

    private async Task ShareToThreads()
    {
        try
        {
            var url = NavigationManager.Uri;
            var text = L["share.defaultText"];
            var combinedText = $"{text} {url}";
            var shareUrl = $"https://threads.net/intent/post?text={Uri.EscapeDataString(combinedText)}";
            
            Console.WriteLine($"[ShareButton] Sharing to Threads: {shareUrl}");
            await JS.InvokeVoidAsync("shareHelper.openShareWindow", shareUrl, "Share to Threads", 600, 700);
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"[ShareButton] Share to Threads failed: {ex.Message}");
        }
        finally
        {
            _isOpen = false;
        }
    }

    private async Task ShareToReddit()
    {
        try
        {
            var url = NavigationManager.Uri;
            var title = L["share.defaultText"];
            var shareUrl = $"https://www.reddit.com/submit?url={Uri.EscapeDataString(url)}&title={Uri.EscapeDataString(title)}";
            
            Console.WriteLine($"[ShareButton] Sharing to Reddit: {shareUrl}");
            await JS.InvokeVoidAsync("shareHelper.openShareWindow", shareUrl, "Share to Reddit", 800, 600);
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"[ShareButton] Share to Reddit failed: {ex.Message}");
        }
        finally
        {
            _isOpen = false;
        }
    }

    public void Dispose()
    {
        if (_dotNetRef != null)
        {
            try
            {
                JS.InvokeVoidAsync("popoverHelper.unregister", "share-button-container");
            }
            catch { /* Ignore disposal errors */ }
            _dotNetRef.Dispose();
        }
    }
}
