@using SortAlgorithm.VisualizationWeb.Models
@using SortAlgorithm.VisualizationWeb.Services
@inject IJSRuntime JS
@inject DebugSettings DebugSettings
@inject LocalizationService L

<button class="cst-trigger-btn" @onclick="TogglePanel" title="@L["comparisonStats.title"]">
    📊 Stats
</button>

@if (IsOpen)
{
    <div class="cst-overlay" @onclick="CloseModal">
        <div class="cst-dialog" @onclick:stopPropagation="true">

            <div class="cst-dialog-header">
                <button class="cst-close-btn" @onclick="CloseModal" title="@L["comparisonStats.close"]">✕</button>
                <h3 class="cst-dialog-title">📊 @L["comparisonStats.title"]</h3>
                <div class="cst-header-controls">
                    <span class="cst-sort-label">@L["comparisonStats.sortBy"]</span>
                    <select class="cst-sort-select" value="@_sortColumn" @onchange="OnSortChanged">
                        <option value="ExecTime">@L["comparisonStats.execTime"]</option>
                        <option value="Algorithm">@L["comparisonStats.algorithm"]</option>
                        <option value="Compares">@L["comparisonStats.compares"]</option>
                        <option value="Swaps">@L["comparisonStats.swaps"]</option>
                        <option value="Reads">@L["comparisonStats.reads"]</option>
                        <option value="Writes">@L["comparisonStats.writes"]</option>
                    </select>
                    <div class="cst-copy-dropdown">
                        <button class="cst-copy-btn" @onclick="ToggleCopyMenu" title="@L["comparisonStats.copyToClipboard"]">
                            📋 @L["comparisonStats.copy"]
                        </button>
                        @if (_showCopyMenu)
                        {
                            <div class="cst-copy-menu">
                                <button class="cst-copy-menu-item" @onclick="() => CopyToClipboard(CopyFormat.Tsv)">
                                    📋 @L["comparisonStats.copyTsv"]
                                </button>
                                <button class="cst-copy-menu-item" @onclick="() => CopyToClipboard(CopyFormat.Json)">
                                    📄 @L["comparisonStats.copyJson"]
                                </button>
                                <button class="cst-copy-menu-item" @onclick="() => CopyToClipboard(CopyFormat.Markdown)">
                                    📝 @L["comparisonStats.copyMarkdown"]
                                </button>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="cst-card-list">
                @{
                    var sortedList = GetSortedInstances().ToList();
                    var maxCompares = sortedList.Count > 0 ? sortedList.Max(x => x.State.CompareCount) : 0UL;
                    var maxSwaps = sortedList.Count > 0 ? sortedList.Max(x => x.State.SwapCount) : 0UL;
                    var maxReads = sortedList.Count > 0 ? sortedList.Max(x => x.State.IndexReadCount) : 0UL;
                    var maxWrites = sortedList.Count > 0 ? sortedList.Max(x => x.State.IndexWriteCount) : 0UL;

                    var minCompares = sortedList.Where(x => x.State.CompareCount > 0).Select(x => x.State.CompareCount).DefaultIfEmpty(0UL).Min();
                    var minSwaps = sortedList.Where(x => x.State.SwapCount > 0).Select(x => x.State.SwapCount).DefaultIfEmpty(0UL).Min();
                    var minReads = sortedList.Where(x => x.State.IndexReadCount > 0).Select(x => x.State.IndexReadCount).DefaultIfEmpty(0UL).Min();
                    var minWrites = sortedList.Where(x => x.State.IndexWriteCount > 0).Select(x => x.State.IndexWriteCount).DefaultIfEmpty(0UL).Min();
                }
                @for (int i = 0; i < sortedList.Count; i++)
                {
                    var item = sortedList[i];
                    var rank = i + 1;

                    var cmPct = maxCompares > 0 ? (int)(item.State.CompareCount * 100 / maxCompares) : 0;
                    var swPct = maxSwaps > 0 ? (int)(item.State.SwapCount * 100 / maxSwaps) : 0;
                    var rdPct = maxReads > 0 ? (int)(item.State.IndexReadCount * 100 / maxReads) : 0;
                    var wrPct = maxWrites > 0 ? (int)(item.State.IndexWriteCount * 100 / maxWrites) : 0;

                    var cmBest = minCompares > 0 && item.State.CompareCount == minCompares;
                    var swBest = minSwaps > 0 && item.State.SwapCount == minSwaps;
                    var rdBest = minReads > 0 && item.State.IndexReadCount == minReads;
                    var wrBest = minWrites > 0 && item.State.IndexWriteCount == minWrites;

                    <div class="cst-card @(item.State.IsSortCompleted ? "cst-card--done" : "")">
                        <div class="cst-card-header">
                            <span class="cst-rank">@GetRankLabel(rank)</span>
                            <span class="cst-algo-name">@item.AlgorithmName</span>
                            <span class="cst-complexity">@item.Metadata.TimeComplexity</span>
                            <span class="cst-exec-time">⏱ @FormatTotalTime(item.State.ActualExecutionTime)</span>
                            <span class="cst-status @(item.State.IsSortCompleted ? "cst-status--done" : "cst-status--running")">
                                @(item.State.IsSortCompleted ? "✅ 100%" : $"🔄 {GetProgressPercentage(item)}%")
                            </span>
                        </div>
                        <div class="cst-metrics">
                            <div class="cst-metric-row">
                                <span class="cst-metric-label">@L["comparisonStats.compares"]</span>
                                <div class="cst-bar-track">
                                    <div class="cst-bar-fill @(cmBest ? "cst-bar-fill--best" : "")" style="width: @cmPct%"></div>
                                </div>
                                <span class="cst-metric-value @(cmBest ? "cst-metric-value--best" : "")">
                                    @item.State.CompareCount.ToString("N0")@(cmBest ? " 🏆" : "")
                                </span>
                            </div>
                            <div class="cst-metric-row">
                                <span class="cst-metric-label">@L["comparisonStats.swaps"]</span>
                                <div class="cst-bar-track">
                                    <div class="cst-bar-fill @(swBest ? "cst-bar-fill--best" : "")" style="width: @swPct%"></div>
                                </div>
                                <span class="cst-metric-value @(swBest ? "cst-metric-value--best" : "")">
                                    @item.State.SwapCount.ToString("N0")@(swBest ? " 🏆" : "")
                                </span>
                            </div>
                            <div class="cst-metric-row">
                                <span class="cst-metric-label">@L["comparisonStats.reads"]</span>
                                <div class="cst-bar-track">
                                    <div class="cst-bar-fill @(rdBest ? "cst-bar-fill--best" : "")" style="width: @rdPct%"></div>
                                </div>
                                <span class="cst-metric-value @(rdBest ? "cst-metric-value--best" : "")">
                                    @item.State.IndexReadCount.ToString("N0")@(rdBest ? " 🏆" : "")
                                </span>
                            </div>
                            <div class="cst-metric-row">
                                <span class="cst-metric-label">@L["comparisonStats.writes"]</span>
                                <div class="cst-bar-track">
                                    <div class="cst-bar-fill @(wrBest ? "cst-bar-fill--best" : "")" style="width: @wrPct%"></div>
                                </div>
                                <span class="cst-metric-value @(wrBest ? "cst-metric-value--best" : "")">
                                    @item.State.IndexWriteCount.ToString("N0")@(wrBest ? " 🏆" : "")
                                </span>
                            </div>
                        </div>
                    </div>
                }
            </div>

        </div>
    </div>
}

@code {
[Parameter, EditorRequired]
public List<ComparisonInstance> Instances { get; set; } = null!;

[Parameter]
public bool IsOpen { get; set; } = false;

[Parameter]
public EventCallback<bool> IsOpenChanged { get; set; }

private string _sortColumn = "ExecTime";
private bool _showCopyMenu = false;

private enum CopyFormat
{
    Tsv,
    Json,
    Markdown
}

    private static string GetRankLabel(int rank) => rank switch
    {
        1 => "🥇",
        2 => "🥈",
        3 => "🥉",
        _ => $"{rank}",
    };

    private static int GetProgressPercentage(ComparisonInstance item)
    {
        if (item.State.TotalOperations == 0) return 0;
        return (int)((item.State.CurrentOperationIndex / (double)item.State.TotalOperations) * 100);
    }

    private static string FormatTotalTime(TimeSpan time)
    {
        if (time == TimeSpan.Zero) return "-";
        if (time.TotalNanoseconds < 1000)
            return $"{time.TotalNanoseconds:F0} ns";
        else if (time.TotalMicroseconds < 1000)
            return $"{TrimTrailingZerosMinOne(time.TotalMicroseconds)} μs";
        else if (time.TotalMilliseconds < 1000)
            return $"{TrimTrailingZerosMinOne(time.TotalMilliseconds)} ms";
        else
            return $"{TrimTrailingZerosMinOne(time.TotalSeconds)} s";
    }

    private static string TrimTrailingZerosMinOne(double value)
    {
        var s = value.ToString("F3").TrimEnd('0');
        if (s.EndsWith('.'))
            s += "0";
        return s;
    }

    private async Task TogglePanel()
    {
        IsOpen = !IsOpen;
        await IsOpenChanged.InvokeAsync(IsOpen);
    }

    private async Task CloseModal()
    {
        IsOpen = false;
        await IsOpenChanged.InvokeAsync(false);
    }

    private void OnSortChanged(ChangeEventArgs e)
    {
        _sortColumn = e.Value?.ToString() ?? "ExecTime";
    }

    private void ToggleCopyMenu()
    {
        _showCopyMenu = !_showCopyMenu;
    }

    private IEnumerable<ComparisonInstance> GetSortedInstances()
    {
        return _sortColumn switch
        {
            "Algorithm" => Instances.OrderBy(x => x.AlgorithmName),
            "ExecTime" => Instances.OrderBy(x => x.State.ActualExecutionTime),
            "Swaps" => Instances.OrderBy(x => x.State.SwapCount),
            "Reads" => Instances.OrderBy(x => x.State.IndexReadCount),
            "Writes" => Instances.OrderBy(x => x.State.IndexWriteCount),
            _ => Instances.OrderBy(x => x.State.CompareCount),
        };
    }

    private async Task CopyToClipboard(CopyFormat format)
    {
        _showCopyMenu = false;

        var sortedList = GetSortedInstances().ToList();
        string content = format switch
        {
            CopyFormat.Json => GenerateJson(sortedList),
            CopyFormat.Markdown => GenerateMarkdown(sortedList),
            _ => GenerateTsv(sortedList),
        };

        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", content);
            DebugSettings.Log($"[ComparisonStatsTable] Copied as {format}");
        }
        catch (Exception ex)
        {
            DebugSettings.Log($"[ComparisonStatsTable] Failed to copy: {ex.Message}");
        }
    }

    private string GenerateTsv(List<ComparisonInstance> items)
    {
        var header = "Rank\tAlgorithm\tComplexity\tCompares\tSwaps\tReads\tWrites\tProgress\tExec Time";
        var rank = 1;
        var rows = items.Select(item =>
        {
            var progress = GetProgressPercentage(item);
            return $"{rank++}\t" +
                   $"{item.AlgorithmName}\t" +
                   $"{item.Metadata.TimeComplexity}\t" +
                   $"{item.State.CompareCount}\t" +
                   $"{item.State.SwapCount}\t" +
                   $"{item.State.IndexReadCount}\t" +
                   $"{item.State.IndexWriteCount}\t" +
                   $"{(item.State.IsSortCompleted ? "100%" : $"{progress}%")}\t" +
                   $"{FormatTotalTime(item.State.ActualExecutionTime)}";
        });

        return header + "\n" + string.Join("\n", rows);
    }

    private string GenerateJson(List<ComparisonInstance> items)
    {
        var rank = 1;
        var data = items.Select(item => new ComparisonStatsDto
        {
            Rank = rank++,
            Algorithm = item.AlgorithmName,
            Complexity = item.Metadata.TimeComplexity,
            Compares = item.State.CompareCount,
            Swaps = item.State.SwapCount,
            Reads = item.State.IndexReadCount,
            Writes = item.State.IndexWriteCount,
            Progress = item.State.IsSortCompleted ? 100 : GetProgressPercentage(item),
            IsCompleted = item.State.IsSortCompleted,
            ExecutionTime = new ExecutionTimeDto
            {
                TotalNanoseconds = item.State.ActualExecutionTime.TotalNanoseconds,
                Formatted = FormatTotalTime(item.State.ActualExecutionTime)
            }
        }).ToList();

        return System.Text.Json.JsonSerializer.Serialize(data, ComparisonStatsJsonContext.Default.ListComparisonStatsDto);
    }

    private string GenerateMarkdown(List<ComparisonInstance> items)
    {
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("| Rank | Algorithm | Complexity | Compares | Swaps | Reads | Writes | Progress | Exec Time |");
        sb.AppendLine("|------|-----------|------------|----------|-------|-------|--------|----------|-----------|");

        var rank = 1;
        foreach (var item in items)
        {
            var progress = item.State.IsSortCompleted ? "100%" : $"{GetProgressPercentage(item)}%";
            sb.AppendLine($"| {rank} | {item.AlgorithmName} | {item.Metadata.TimeComplexity} | " +
                         $"{item.State.CompareCount:N0} | {item.State.SwapCount:N0} | " +
                         $"{item.State.IndexReadCount:N0} | {item.State.IndexWriteCount:N0} | " +
                         $"{progress} | {FormatTotalTime(item.State.ActualExecutionTime)} |");
            rank++;
        }

        return sb.ToString();
    }
}
