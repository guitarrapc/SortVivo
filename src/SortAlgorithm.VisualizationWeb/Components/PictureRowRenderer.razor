@using SortAlgorithm.VisualizationWeb.Models
@using SortAlgorithm.VisualizationWeb.Services
@using Microsoft.JSInterop
@inject IJSRuntime JS
@inject DebugSettings DebugSettings
@inject RenderSettings RenderSettings
@implements IAsyncDisposable

<div id="@_dropZoneId"
class="picture-row-container @(State?.PlaybackState == PlaybackState.Playing ? "playing" : "") @(_isDragOver ? "drag-over" : "")"
@onclick="OnCanvasClick"
style="position: relative; width: 100%; height: 100%; align-self: stretch;">

    @if (State != null && State.MainArray.Length > 0)
    {
        <canvas @key="_canvasId" id="@_canvasId" style="width: 100%; height: 100%; display: block;"></canvas>

        @* 画像変更ボタン（右上に表示） *@
        <label style="position: absolute; top: 8px; right: 8px; z-index: 10;
                      background: rgba(0,0,0,0.6); color: #fff; border: 1px solid #555;
                      border-radius: 6px; padding: 4px 10px; font-size: 0.8rem; cursor: pointer;
                      user-select: none;"
               @onclick:stopPropagation="true"
               title="Upload image to visualize">
            📷 @(_imageLoaded ? "Change Image" : "Upload Image")
            <InputFile OnChange="HandleFileUpload"
                       accept="image/*"
                       style="display: none;" />
        </label>

        @* ドラッグオーバー時のオーバーレイ *@
        @if (_isDragOver)
        {
            <div style="position: absolute; inset: 0; z-index: 20; pointer-events: none;
                        background: rgba(59,130,246,0.25); border: 3px dashed #3B82F6;
                        border-radius: 4px; display: flex; align-items: center; justify-content: center;">
                <span style="color: #fff; font-size: 1.4rem; text-shadow: 0 1px 4px rgba(0,0,0,0.8);">
                    🖼️ Drop image here
                </span>
            </div>
        }
    }
    else
    {
        @* 初期状態: 画像アップロード UI *@
        <div style="text-align: center; color: #999; height: 100%; display: flex; flex-direction: column;
                    justify-content: center; align-items: center; gap: 1rem;
                    @(_isDragOver ? "outline: 3px dashed #3B82F6; outline-offset: -12px; background: rgba(59,130,246,0.08);" : "")">
            <p style="font-size: 2.5rem; margin: 0;">@(_isDragOver ? "🖼️" : "🖼️")</p>
            @if (_isDragOver)
            {
                <p style="margin: 0; color: #3B82F6; font-weight: bold;">Drop image here</p>
            }
            else
            {
                <p style="margin: 0;">Click "Generate &amp; Sort" to start visualization</p>
                <p style="margin: 0; font-size: 0.85rem; color: #666;">
                    Upload or drag &amp; drop an image to sort its rows
                </p>
                <label style="background: #3B82F6; color: #fff; border: none; border-radius: 6px;
                              padding: 8px 20px; font-size: 0.9rem; cursor: pointer; user-select: none;">
                    📷 @(_imageLoaded ? "Change Image" : "Upload Image")
                    <InputFile OnChange="HandleFileUpload"
                               accept="image/*"
                               style="display: none;" />
                </label>
                @if (_imageLoaded)
                {
                    <p style="margin: 0; font-size: 0.85rem; color: #10B981;">✅ Image loaded</p>
                }
            }
        </div>
    }
</div>

@code {
    [Parameter]
    public VisualizationState? State { get; set; }

    [Parameter]
    public EventCallback OnClick { get; set; }

    [Parameter]
    public int GridColumnCount { get; set; } = 1;

    private string _canvasId   = $"sortPictureRowCanvas_{Guid.NewGuid():N}";
    private string _dropZoneId = $"sortPictureRowDrop_{Guid.NewGuid():N}";
    private bool _isInitialized = false;
    private bool _isInitializing = false;
    private bool _isDropZoneRegistered = false;
    private bool _previousHasData = false;
    private int _lastSortVersion = -1;

    // 画像データ
    private bool _imageLoaded = false;
    private string? _imageDataUrl = null;
    private bool _previousImageLoaded = false;

    // ドラッグ状態
    private bool _isDragOver = false;
    private bool _previousIsDragOver = false;

    // DotNetObjectReference（ドラッグ＆ドロップ JS コールバック用）
    private DotNetObjectReference<PictureRowRenderer>? _dotNetRef;

    protected override void OnInitialized()
    {
        RenderSettings.OnChanged += OnRenderSettingsChanged;
        _dotNetRef = DotNetObjectReference.Create(this);
    }

    private void OnRenderSettingsChanged()
    {
        InvokeAsync(async () =>
        {
            var oldCanvasId   = _canvasId;
            var oldDropZoneId = _dropZoneId;
            var wasInitialized = _isInitialized;

            _canvasId   = $"sortPictureRowCanvas_{Guid.NewGuid():N}";
            _dropZoneId = $"sortPictureRowDrop_{Guid.NewGuid():N}";
            _isInitialized = false;
            _isDropZoneRegistered = false;
            _lastSortVersion = -1;
            StateHasChanged();

            if (wasInitialized)
            {
                try { await JS.InvokeVoidAsync("pictureRowCanvasRenderer.dispose", oldCanvasId); } catch { }
            }
            try { await JS.InvokeVoidAsync("pictureRowCanvasRenderer.disposeDropZone", oldDropZoneId); } catch { }
        });
    }

    protected override bool ShouldRender()
    {
        var hasData = State?.MainArray.Length > 0;
        var shouldRender = _previousHasData != hasData
                        || (hasData && !_isInitialized)  // キャンバスが DOM に存在する場合のみ再描画トリガー
                        || _previousImageLoaded != _imageLoaded
                        || _previousIsDragOver  != _isDragOver;
        _previousHasData    = hasData;
        _previousImageLoaded = _imageLoaded;
        _previousIsDragOver  = _isDragOver;
        return shouldRender;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!_isInitialized) return;
        await RenderCanvas();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // ドロップゾーンは DOM が確定してから登録（初回のみ）
        if (!_isDropZoneRegistered && _dotNetRef != null)
        {
            try
            {
                await JS.InvokeVoidAsync("pictureRowCanvasRenderer.setupDropZone", _dropZoneId, _dotNetRef);
                _isDropZoneRegistered = true;
            }
            catch { /* DOM がまだ存在しない場合はスキップ */ }
        }

        // Canvas の初期化（配列がある場合のみ canvas 要素が DOM に存在する）
        if (State?.MainArray.Length == 0) return;

        if (_isInitialized || _isInitializing) return;
        _isInitializing = true;
        var targetCanvasId = _canvasId;

        try
        {
            var success = await JS.InvokeAsync<bool>("pictureRowCanvasRenderer.initialize", targetCanvasId, RenderSettings.UseWebGL);
            if (success && _canvasId == targetCanvasId)
            {
                _isInitialized = true;
                await RenderCanvas();
            }
        }
        finally
        {
            _isInitializing = false;
            if (!_isInitialized)
                StateHasChanged();
        }
    }

    private async Task RenderCanvas()
    {
        if (!_isInitialized || State == null || State.MainArray.Length == 0) return;

        try
        {
            if (_lastSortVersion != State.SortVersion)
            {
                _lastSortVersion = State.SortVersion;
                // 行数が変わる可能性があるため、ソートバージョン変化時に画像を再設定する
                if (_imageLoaded && _imageDataUrl != null)
                {
                    await JS.InvokeVoidAsync("pictureRowCanvasRenderer.setImage",
                        _canvasId, _imageDataUrl, State.MainArray.Length);
                }
                await JS.InvokeVoidAsync("pictureRowCanvasRenderer.setArray",
                    _canvasId,
                    State.MainArray,
                    State.BufferArrays,
                    State.CompareIndices,
                    State.SwapIndices,
                    State.ReadIndices,
                    State.WriteIndices,
                    State.IsSortCompleted,
                    State.ShowCompletionHighlight);
            }
            else if (State.MainArrayDelta != null)
            {
                await JS.InvokeVoidAsync("pictureRowCanvasRenderer.applyFrame",
                    _canvasId,
                    State.MainArrayDelta,
                    State.BufferArrayDeltas,
                    State.CompareIndices,
                    State.SwapIndices,
                    State.ReadIndices,
                    State.WriteIndices,
                    State.IsSortCompleted,
                    State.ShowCompletionHighlight);
            }
            else
            {
                await JS.InvokeVoidAsync("pictureRowCanvasRenderer.updateData",
                    _canvasId,
                    State.MainArray,
                    State.CompareIndices,
                    State.SwapIndices,
                    State.ReadIndices,
                    State.WriteIndices,
                    State.IsSortCompleted,
                    State.BufferArrays,
                    State.ShowCompletionHighlight);
            }
        }
        catch (Exception ex)
        {
            DebugSettings.Log($"PictureRow Canvas render error: {ex.Message}");
        }
    }

    // ─── ドラッグ＆ドロップ JS コールバック ──────────────────────────────

    /// <summary>ドラッグ状態の変化を JS から受け取る</summary>
    [JSInvokable]
    public void OnDragStateChanged(bool isDragOver)
    {
        _isDragOver = isDragOver;
        InvokeAsync(StateHasChanged);
    }

    /// <summary>ドロップされたファイルの dataURL を JS から受け取る</summary>
    [JSInvokable]
    public async Task OnFileDropped(string dataUrl, string fileName, long fileSize)
    {
        DebugSettings.Log($"[PictureRowRenderer] File dropped: {fileName} ({fileSize} bytes)");
        await LoadImageFromDataUrl(dataUrl);
    }

    /// <summary>ドロップエラーを JS から受け取る</summary>
    [JSInvokable]
    public void OnDropError(string message)
    {
        DebugSettings.Log($"[PictureRowRenderer] Drop error: {message}");
    }

    // ─── ファイル選択（InputFile） ──────────────────────────────────────

    /// <summary>
    /// 画像ファイルがアップロードされたときの処理
    /// </summary>
    private async Task HandleFileUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;

        const long maxAllowedSize = 20 * 1024 * 1024; // 20MB
        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            var bytes = ms.ToArray();
            var base64 = Convert.ToBase64String(bytes);
            var dataUrl = $"data:{file.ContentType};base64,{base64}";

            DebugSettings.Log($"[PictureRowRenderer] Image selected: {file.Name} ({bytes.Length} bytes)");
            await LoadImageFromDataUrl(dataUrl);
        }
        catch (Exception ex)
        {
            DebugSettings.Log($"[PictureRowRenderer] Image load error: {ex.Message}");
        }
    }

    /// <summary>dataURL を受け取って共通処理（ファイル選択 / ドロップ 両対応）</summary>
    private async Task LoadImageFromDataUrl(string dataUrl)
    {
        _imageDataUrl = dataUrl;
        _imageLoaded = true;

        if (_isInitialized && State?.MainArray.Length > 0)
        {
            await JS.InvokeVoidAsync("pictureRowCanvasRenderer.setImage",
                _canvasId, _imageDataUrl, State.MainArray.Length);
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task OnCanvasClick()
    {
        await OnClick.InvokeAsync();
    }

    public async ValueTask DisposeAsync()
    {
        RenderSettings.OnChanged -= OnRenderSettingsChanged;
        DebugSettings.Log($"[PictureRowRenderer] DisposeAsync called for canvas: {_canvasId}");

        try { await JS.InvokeVoidAsync("pictureRowCanvasRenderer.disposeDropZone", _dropZoneId); } catch { }

        if (_isInitialized)
        {
            try
            {
                await JS.InvokeVoidAsync("pictureRowCanvasRenderer.dispose", _canvasId);
                DebugSettings.Log($"[PictureRowRenderer] Successfully disposed canvas: {_canvasId}");
            }
            catch (Exception ex)
            {
                DebugSettings.Log($"[PictureRowRenderer] ERROR disposing canvas {_canvasId}: {ex.Message}");
            }
        }
        else
        {
            DebugSettings.Log($"[PictureRowRenderer] Canvas {_canvasId} was not initialized, skipping dispose");
        }

        _dotNetRef?.Dispose();
    }
}
