@page "/"
@using SortAlgorithm.VisualizationWeb.Models
@using SortAlgorithm.VisualizationWeb.Services
@using SortAlgorithm.VisualizationWeb.Components
@using Microsoft.JSInterop
@inject PlaybackService Playback
@inject SortExecutor Executor
@inject AlgorithmRegistry AlgorithmRegistry
@inject ArrayPatternRegistry ArrayPatternRegistry
@inject ComparisonModeService ComparisonMode
@inject DebugSettings DebugSettings
@inject RenderSettings RenderSettings
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>Sort Algorithm Visualization</PageTitle>

<div class="visualization-page"
     style="--sidebar-width: @(_sidebarCollapsed ? "40" : _sidebarWidth)px; user-select: @(_isResizing ? "none" : "auto");"
     @onmousemove="OnMouseMove"
     @onmouseup="OnMouseUp"
     @onmousemove:preventDefault="@_isResizing">
    <div class="header">
        @* モバイル / タブレット: ☰ ハンバーガーボタン *@
        <button class="header__hamburger"
                @onclick="() => _quickAccessOpen = true"
                title="Open Quick Access Panel">☰</button>

        <h1 class="header__title">
            🎨 Sort Visualization
        </h1>

        <div class="header__actions">
            <NavLink href="tutorial" class="tutorial-nav-btn" title="チュートリアルへ">🎓 Tutorial</NavLink>
            <button class="header__settings-btn" @onclick="() => _settingsOpen = true" title="Settings">⚙ Settings</button>
        </div>
    </div>

    <QuickAccessPanel
        @bind-IsCollapsed="_sidebarCollapsed"
        @bind-SelectedAlgorithm="SelectedAlgorithm"
        @bind-ArraySize="ArraySize"
        @bind-SelectedPatternName="SelectedPatternName"
        @bind-SelectedVisualizationMode="SelectedVisualizationMode"
        @bind-IsComparisonMode="_isComparisonMode"
        @bind-SelectedCategory="_selectedCategory"
        @bind-AutoSwitchToRecommendedSize="_autoSwitchToRecommendedSize"
        IsOpen="_quickAccessOpen"
        OnClose="() => _quickAccessOpen = false"
        OnResizeStart="HandleResizeStart"
        IsLoading="IsLoading"
        Playback="Playback"
        ComparisonMode="ComparisonMode"
        RenderSettings="RenderSettings"
        DebugSettings="DebugSettings"
        OnGenerateAndSort="GenerateAndSortAsync"
        OnAddAlgorithm="AddAlgorithmToComparison"
        OnAlgorithmChanged="OnAlgorithmChanged"
        OnVisualizationModeChanged="OnVisualizationModeChanged"
        OnSpeedSettingsChanged="OnSpeedSettingsChanged"
        OnComparisonModeChanged="OnComparisonModeChanged" />

    <SettingsModal
        IsOpen="_settingsOpen"
        OnClose="() => _settingsOpen = false"
        Playback="Playback"
        RenderSettings="RenderSettings"
        DebugSettings="DebugSettings"
        @bind-AutoSwitchToRecommendedSize="_autoSwitchToRecommendedSize"
        @bind-SelectedCategory="_selectedCategory" />



    <div class="visualization-area">
        @if (IsLoading)
        {
            <div class="loading-overlay">
                <div class="loading-spinner"></div>
                <span>@LoadingMessage</span>
            </div>
        }

        <PlayControlBar IsPlaying="@GetIsPlaying()"
                        SoundEnabled="@Playback.SoundEnabled"
                        StatusText="@GetComparisonStatusText()"
                        OnTogglePlayPause="HandleTogglePlayPause"
                        OnStop="HandleReset"
                        OnToggleSound="HandleToggleSound" />

        <div class="visualization-content">
            @if (_isComparisonMode && ComparisonMode.State.Instances.Any())
            {
                @* 比較モード: SortCardGrid *@
                <SortCardGrid Instances="ComparisonMode.State.Instances"
                              VisualizationMode="SelectedVisualizationMode"
                              OnRemove="RemoveAlgorithmFromComparison"
                              OnVisualizationClick="OnComparisonVisualizationClick" />
            }
            else
            {
                @* 単一モード: SortCard フルサイズ *@
                <SortCard State="Playback.State"
                          AlgorithmName="@SelectedAlgorithm"
                          Complexity="@GetSelectedAlgorithmComplexity()"
                          VisualizationMode="@SelectedVisualizationMode"
                          GridColumnCount="1"
                          CardSize="StatsCardSize.Full"
                          ShowRemoveButton="false"
                          Playback="@Playback"
                          OnVisualizationClick="@OnVisualizationClick" />
            }
        </div>

        @if (!_isComparisonMode)
        {
            <SeekBar CurrentIndex="Playback.State.CurrentOperationIndex"
                     TotalOperations="Playback.State.TotalOperations"
                     OnSeek="OnSeek" />
        }
    </div>

    @* 統計比較表（右側ドッキングパネル） *@
    @if (_isComparisonMode && ComparisonMode.State.Instances.Any())
    {
        <ComparisonStatsTable Instances="ComparisonMode.State.Instances"
                              @bind-IsOpen="_statsTableOpen" />
    }
</div>

@code {
private string SelectedAlgorithm { get; set; } = "Bubble sort";
private int ArraySize { get; set; } = 64;
private string SelectedPatternName { get; set; } = "🎲 Random";
private VisualizationMode SelectedVisualizationMode { get; set; } = VisualizationMode.BarChart;
private string _runningAlgorithmName = string.Empty;

    // ローディング状態
    private LoadingState _loadingState = LoadingState.Idle;
    private bool IsLoading => _loadingState != LoadingState.Idle;
    private string LoadingMessage => _loadingState switch
    {
        LoadingState.Sorting => "⏳ Sorting...",
        LoadingState.AddingAlgorithm => "⏳ Adding algorithm...",
        LoadingState.LoadingImage => "⏳ Loading image...",
        _ => "",
    };

    // 比較モード関連
    private bool _isComparisonMode = false;
    private bool _isComparisonPlaying = false;
    private bool _statsTableOpen = false;

    // Quick Access パネル（モバイル / タブレット）
    private bool _quickAccessOpen = false;

    // Settings モーダル
    private bool _settingsOpen = false;

    // Settings: QuickAccessPanel と共有する設定
    private string _selectedCategory = string.Empty;
    private bool _autoSwitchToRecommendedSize = false;

    // サイドバーリサイズ関連
    private int _sidebarWidth = 280; // デフォルト幅（px）
    private bool _sidebarCollapsed = false; // 折りたたみ状態
    private bool _isResizing = false;
    private int _resizeStartX = 0;
    private int _resizeStartWidth = 0;

    protected override void OnInitialized()
    {
        Playback.StateChanged += OnStateChanged;
        ComparisonMode.OnStateChanged += OnStateChanged;
        DebugSettings.OnChanged += OnStateChanged;

        // 初期モードを同期
        SelectedVisualizationMode = Playback.State.Mode;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("debugHelper.setDebugMode", DebugSettings.IsEnabled);
        }
    }

    private void HandleResizeStart(MouseEventArgs e)
    {
        _isResizing = true;
        _resizeStartX = (int)e.ClientX;
        _resizeStartWidth = _sidebarWidth;
    }

    private void OnMouseMove(MouseEventArgs e)
    {
        if (_isResizing)
        {
            var deltaX = (int)e.ClientX - _resizeStartX;
            var newWidth = _resizeStartWidth + deltaX;

            // 最小200px、最大500pxに制限
            _sidebarWidth = Math.Clamp(newWidth, 200, 500);
            StateHasChanged();
        }
    }

    private void OnMouseUp()
    {
        _isResizing = false;
    }

    private void OnAlgorithmChanged()
    {
        StateHasChanged();
    }

    private ArrayPatternMetadata? GetSelectedPattern()
    {
        return ArrayPatternRegistry.GetAllPatterns().FirstOrDefault(p => p.Name == SelectedPatternName);
    }

    private string GetSelectedAlgorithmComplexity()
    {
        var algo = AlgorithmRegistry.GetAllAlgorithms().FirstOrDefault(a => a.Name == SelectedAlgorithm);
        return algo?.TimeComplexity ?? "Unknown";
    }

    private async Task GenerateAndSortAsync()
    {
        var metadata = AlgorithmRegistry.GetAllAlgorithms().FirstOrDefault(a => a.Name == SelectedAlgorithm);
        if (metadata == null)
        {
            DebugSettings.Log($"Algorithm not found: {SelectedAlgorithm}");
            return;
        }

        var pattern = GetSelectedPattern();
        if (pattern == null)
        {
            DebugSettings.Log($"Pattern not found: {SelectedPatternName}");
            return;
        }

        // Update running algorithm name when sort is actually executed
        _runningAlgorithmName = SelectedAlgorithm;

        // 要素数制限を適用（すべてのアルゴリズムで4096まで対応）
        var size = Math.Min(ArraySize, metadata.MaxElements);

        // 選択されたパターンで配列生成
        var random = new Random();
        var array = pattern.Generator(size, random);

        // ローディング表示を開始し、await Task.Yield() でオーバーレイが確定してから重い処理を開始
        _loadingState = LoadingState.Sorting;
        StateHasChanged();
        await Task.Yield();

        // ソート実行と操作記録（ExecuteAndRecordAsync: Task.Yield() でUIスレッドを解放しながら実行）
        try
        {
            var (operations, statistics, actualExecutionTime) = await Executor.ExecuteAndRecordAsync(array, metadata);
            Playback.LoadOperations(array.AsSpan(), operations, statistics, actualExecutionTime);
            DebugSettings.Log($"Loaded {operations.Count} operations for {SelectedAlgorithm} with {pattern.Name} pattern");
        }
        catch (Exception ex)
        {
            DebugSettings.Log($"Error executing sort: {ex.Message}");
        }
        finally
        {
            _loadingState = LoadingState.Idle;
            StateHasChanged();
        }
    }

    // 比較モード関連メソッド
    private void OnComparisonModeChanged()
    {
        DebugSettings.Log($"[OnComparisonModeChanged] Called. _isComparisonMode: {_isComparisonMode}");

        if (_isComparisonMode)
        {
            var pattern = GetSelectedPattern();
            if (pattern == null)
            {
                DebugSettings.Log($"[OnComparisonModeChanged] Pattern not found: {SelectedPatternName}");
                return;
            }

            // 比較モードON: 初期配列を生成して設定
            var size = Math.Min(ArraySize, 4096);
            DebugSettings.Log($"[OnComparisonModeChanged] Generating array of size: {size} with pattern: {pattern.Name}");
            var random = new Random();
            var array = pattern.Generator(size, random);
            DebugSettings.Log($"[OnComparisonModeChanged] Generated array length: {array.Length}");

            ComparisonMode.Enable(array, size, pattern);

            // サイドバーの速度設定を比較モードに適用
            ComparisonMode.SetSpeedForAll(Playback.OperationsPerFrame, Playback.SpeedMultiplier);

            DebugSettings.Log($"[OnComparisonModeChanged] Comparison mode enabled with {pattern.Name} pattern");
        }
        else
        {
            // 比較モードOFF: クリーンアップ
            ComparisonMode.Disable();
            _runningAlgorithmName = string.Empty;
            DebugSettings.Log("Comparison mode disabled");
        }
        StateHasChanged();
    }



    private async Task AddAlgorithmToComparison()
    {
        if (ComparisonMode.IsAddingAlgorithm) return;

        var pattern = GetSelectedPattern();
        if (pattern == null)
        {
            DebugSettings.Log($"[Index] Pattern not found: {SelectedPatternName}");
            return;
        }

        DebugSettings.Log($"[Index] AddAlgorithmToComparison called");
        DebugSettings.Log($"[Index] _isComparisonMode: {_isComparisonMode}");
        DebugSettings.Log($"[Index] ComparisonMode.State.IsEnabled: {ComparisonMode.State.IsEnabled}");
        DebugSettings.Log($"[Index] ComparisonMode.State.CurrentArraySize: {ComparisonMode.State.CurrentArraySize}");
        DebugSettings.Log($"[Index] ComparisonMode.State.CurrentPattern: {ComparisonMode.State.CurrentPattern?.Name}");
        DebugSettings.Log($"[Index] Current ArraySize: {ArraySize}");
        DebugSettings.Log($"[Index] Current Pattern: {pattern.Name}");
        DebugSettings.Log($"[Index] Existing instances count: {ComparisonMode.State.Instances.Count}");
        foreach (var inst in ComparisonMode.State.Instances)
        {
            DebugSettings.Log($"[Index]   - {inst.AlgorithmName}: {inst.State.MainArray.Length} elements");
        }

        // 🔧 Array SizeまたはPatternが変更されている場合、既存のアルゴリズムを新しい設定で再実行
        var currentSize = Math.Min(ArraySize, 4096);
        var needRegeneration = ComparisonMode.State.CurrentArraySize != currentSize
                            || ComparisonMode.State.CurrentPattern?.Name != pattern.Name;

        DebugSettings.Log($"[Index] NeedRegeneration: {needRegeneration} (size: {ComparisonMode.State.CurrentArraySize} vs {currentSize}, pattern: {ComparisonMode.State.CurrentPattern?.Name} vs {pattern.Name})");

        // メタデータチェックをローディング前に行う（インスタンスリストに依存しないので早期に検証）
        var metadata = AlgorithmRegistry.GetAllAlgorithms().FirstOrDefault(a => a.Name == SelectedAlgorithm);
        if (metadata == null)
        {
            DebugSettings.Log($"[Index] Algorithm not found: {SelectedAlgorithm}");
            return;
        }

        // needRegeneration なしで既に追加済みならオーバーレイなしで早期リターン
        if (!needRegeneration && ComparisonMode.State.Instances.Any(x => x.AlgorithmName == SelectedAlgorithm))
        {
            DebugSettings.Log($"[Index] {SelectedAlgorithm} is already in comparison");
            return;
        }

        // ローディング表示を開始し、await Task.Yield() でオーバーレイが確定してから重い処理を開始
        _loadingState = LoadingState.AddingAlgorithm;
        StateHasChanged();
        await Task.Yield();

        try
        {
            if (needRegeneration && ComparisonMode.State.Instances.Any())
            {
                DebugSettings.Log($"[Index] ✅ Settings changed - regenerating all existing algorithms");
                DebugSettings.Log($"[Index]    Old: size={ComparisonMode.State.CurrentArraySize}, pattern={ComparisonMode.State.CurrentPattern?.Name}");
                DebugSettings.Log($"[Index]    New: size={currentSize}, pattern={pattern.Name}");

                // 既存のアルゴリズム情報を保存
                var existingAlgorithms = ComparisonMode.State.Instances
                    .Select(i => new { i.AlgorithmName, i.Metadata })
                    .ToList();

                DebugSettings.Log($"[Index] Saved {existingAlgorithms.Count} existing algorithms");

                // 新しい配列を生成
                var random = new Random();
                var newArray = pattern.Generator(currentSize, random);
                DebugSettings.Log($"[Index] Generated new array: {newArray.Length} elements with pattern {pattern.Name}");

                ComparisonMode.Enable(newArray, currentSize, pattern);
                DebugSettings.Log($"[Index] Called Enable() - instances should be cleared now");

                // すべてのアルゴリズムを新しい設定で再追加
                foreach (var algo in existingAlgorithms)
                {
                    await ComparisonMode.AddAlgorithmAsync(algo.AlgorithmName, algo.Metadata);
                    DebugSettings.Log($"[Index] Re-added {algo.AlgorithmName} with new settings");

                    // 追加直後に速度設定を適用
                    ComparisonMode.SetSpeedForAll(Playback.OperationsPerFrame, Playback.SpeedMultiplier);
                }

                DebugSettings.Log($"[Index] After re-adding, instances count: {ComparisonMode.State.Instances.Count}");
            }
            else if (needRegeneration)
            {
                DebugSettings.Log($"[Index] ⚠️ No existing instances, just updating settings");

                // アルゴリズムがまだない場合は、単純に設定を更新
                var random = new Random();
                var newArray = pattern.Generator(currentSize, random);
                ComparisonMode.Enable(newArray, currentSize, pattern);

                // 速度設定を再適用（パターン変更後にリセットされるのを防ぐ）
                ComparisonMode.SetSpeedForAll(Playback.OperationsPerFrame, Playback.SpeedMultiplier);
            }
            else
            {
                DebugSettings.Log($"[Index] ℹ️ Settings unchanged, using existing configuration");
            }

            // needRegeneration 後に再チェック（再生成で既に含まれていれば追加しない）
            if (ComparisonMode.State.Instances.Any(x => x.AlgorithmName == SelectedAlgorithm))
            {
                DebugSettings.Log($"[Index] {SelectedAlgorithm} is already in comparison");
                return;
            }

            DebugSettings.Log($"[Index] Adding new algorithm: {SelectedAlgorithm}");
            await ComparisonMode.AddAlgorithmAsync(SelectedAlgorithm, metadata);
            DebugSettings.Log($"[Index] After adding, instances count: {ComparisonMode.State.Instances.Count}");

            // 新しく追加したアルゴリズムにも速度設定を適用
            ComparisonMode.SetSpeedForAll(Playback.OperationsPerFrame, Playback.SpeedMultiplier);
            DebugSettings.Log($"[Index] Applied speed settings to new algorithm: OperationsPerFrame={Playback.OperationsPerFrame}, SpeedMultiplier={Playback.SpeedMultiplier}");
        }
        finally
        {
            _loadingState = LoadingState.Idle;
            StateHasChanged();
        }
    }

    private void RemoveAlgorithmFromComparison(int index)
    {
        DebugSettings.Log($"[Index] RemoveAlgorithmFromComparison called for index: {index}");
        DebugSettings.Log($"[Index] Before removal, instances count: {ComparisonMode.State.Instances.Count}");

        if (index >= 0 && index < ComparisonMode.State.Instances.Count)
        {
            var algorithmName = ComparisonMode.State.Instances[index].AlgorithmName;
            DebugSettings.Log($"[Index] Removing algorithm: {algorithmName}");
        }

        ComparisonMode.RemoveAlgorithm(index);

        DebugSettings.Log($"[Index] After removal, instances count: {ComparisonMode.State.Instances.Count}");
        StateHasChanged();
    }

    private void OnVisualizationClick()
    {
        Playback.TogglePlayPause();
    }

    private void OnComparisonVisualizationClick()
    {
        // 比較モード時：クリックですべてのアルゴリズムをトグル（再生⇔停止）
        if (_isComparisonPlaying)
        {
            ComparisonMode.Pause();
            _isComparisonPlaying = false;
        }
        else
        {
            ComparisonMode.Play();
            _isComparisonPlaying = true;
        }
        StateHasChanged();
    }

    private void OnSeek(int index)
    {
        // ドラッグ中のシークはスロットリングを有効化
        Playback.SeekTo(index, throttle: true);
    }

    private void OnVisualizationModeChanged()
    {
        Playback.State.Mode = SelectedVisualizationMode;
        StateHasChanged();
    }

    private void OnStateChanged()
    {
        // 比較モードの再生状態を同期
        if (_isComparisonMode && ComparisonMode.State.IsEnabled)
        {
            _isComparisonPlaying = ComparisonMode.IsPlaying();
        }

        InvokeAsync(StateHasChanged);
    }

    private void HandleReset()
    {
        if (_isComparisonMode)
        {
            ComparisonMode.Reset();
        }
        else
        {
            Playback.Stop();
        }
    }

    private void HandleTogglePlayPause()
    {
        if (_isComparisonMode)
        {
            if (_isComparisonPlaying)
            {
                ComparisonMode.Pause();
                _isComparisonPlaying = false;
            }
            else
            {
                ComparisonMode.Play();
                _isComparisonPlaying = true;
            }
        }
        else
        {
            Playback.TogglePlayPause();
        }
        StateHasChanged();
    }

    private void OnSpeedSettingsChanged()
    {
        DebugSettings.Log($"[Index] OnSpeedSettingsChanged called. _isComparisonMode: {_isComparisonMode}");
        DebugSettings.Log($"[Index] Current settings: OperationsPerFrame={Playback.OperationsPerFrame}, SpeedMultiplier={Playback.SpeedMultiplier}");

        // 比較モードが有効な場合、すべてのアルゴリズムに速度設定を適用
        if (_isComparisonMode)
        {
            ComparisonMode.SetSpeedForAll(Playback.OperationsPerFrame, Playback.SpeedMultiplier);
            DebugSettings.Log($"[Index] SetSpeedForAll called with ops={Playback.OperationsPerFrame}, speed={Playback.SpeedMultiplier}");

            // 適用後の確認
            foreach (var instance in ComparisonMode.State.Instances)
            {
                DebugSettings.Log($"[Index]   {instance.AlgorithmName}: ops={instance.Playback.OperationsPerFrame}, speed={instance.Playback.SpeedMultiplier}");
            }
        }
        StateHasChanged();
    }

    private bool GetIsPlaying()
    {
        if (_isComparisonMode)
            return _isComparisonPlaying;
        return Playback.State.PlaybackState == PlaybackState.Playing;
    }

    private string? GetComparisonStatusText()
    {
        if (!_isComparisonMode || !ComparisonMode.State.Instances.Any())
            return null;

        if (ComparisonMode.State.AllCompleted)
            return "✅ All Completed!";

        var completedCount = ComparisonMode.State.Instances.Count(x => x.State.IsSortCompleted);
        if (completedCount > 0)
            return $"{completedCount}/{ComparisonMode.State.Instances.Count} completed";

        return null;
    }

    private void HandleToggleSound()
    {
        Playback.SoundEnabled = !Playback.SoundEnabled;
    }

    public void Dispose()
    {
        Playback.StateChanged -= OnStateChanged;
        ComparisonMode.OnStateChanged -= OnStateChanged;
    }
}

