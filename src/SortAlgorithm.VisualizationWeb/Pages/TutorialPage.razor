@page "/tutorial"
@page "/tutorial/{AlgorithmName}"
@using SortAlgorithm.VisualizationWeb.Models
@using SortAlgorithm.VisualizationWeb.Services
@using SortAlgorithm.VisualizationWeb.Components
@inject SortExecutor Executor
@inject AlgorithmRegistry AlgorithmRegistry
@inject NavigationManager Navigation
@inject NavigationStateService NavigationState
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>Tutorial</PageTitle>

<div class="tutorial-page" @onkeydown="OnKeyDown" tabindex="0" @ref="_containerRef">

<div class="header">
        <div class="header__left"></div>
        <h1 class="tutorial__title">SORTVIZ TUTORIAL</h1>
        <div class="header__actions">
            <button class="tutorial-close-btn" @onclick="NavigateToHome" title="Close">✕</button>
        </div>
    </div>


    @* ─── カードパネル（PC: 左サイドバー / タブレット+スマホ: 再生コントロールバー上段） ─── *@
    <div class="tutorial-cards-panel">
        <fieldset class="controls-fieldset" disabled="@_isLoading">

            @* ── Sort Target ── *@
            <div class="ui-card">
                <span class="ui-card__title">Sort Target</span>
                <div class="qap__item">
                    <span class="stat-label">Algorithm</span>
                    <select value="@(_selectedAlgorithm?.Name ?? "")"
                            @onchange="OnAlgorithmChanged">
                        @foreach (var category in GetTutorialCategories())
                        {
                            <optgroup label="@category">
                                @foreach (var algo in GetAlgorithmsByCategory(category))
                                {
                                    <option value="@algo.Name">@algo.Name</option>
                                }
                            </optgroup>
                        }
                    </select>
                </div>
            </div>

            @* ── Speed ── *@
            <div class="ui-card">
                <span class="ui-card__title">Speed</span>
                <div class="qap__item qap__item--vertical">
                    <div class="qap__slider-header">
                        <span class="stat-value qap__slider-value">@GetSpeedLabel()</span>
                        <span class="stat-label">(@(_autoPlaySpeedMs) ms)</span>
                    </div>
                    <input type="range" min="0" max="4" step="1"
                           value="@_speedIndex"
                           @oninput="OnSpeedChanged"
                           @onkeydown:stopPropagation
                           style="@RangeTrackStyle(_speedIndex, 0, 4)" />
                </div>
            </div>

        </fieldset>
    </div>

    @* ─── メインエリア ────────────────────────────────────────────────────── *@
    <div class="tutorial-main-area">
        @{
            bool noSteps = _selectedAlgorithm == null || _steps.Count == 0;
        }

        @* ─── 再生コントロールバー ──────────────────────────────────────── *@
        <div class="tutorial-play-control-bar">
            <div class="ctrl-buttons">
                <button class="ctrl-btn" title="First (Home)" @onclick="GoToFirst" disabled="@(noSteps || _currentStepIndex <= -1)">
                    <svg viewBox="0 0 24 24" fill="currentColor">
                        <rect x="4" y="4" width="2" height="16" rx="1"></rect>
                        <polygon points="19 4 7 12 19 20 19 4"></polygon>
                    </svg>
                </button>
                <button class="ctrl-btn" title="Previous (←)" @onclick="GoToPrevious" disabled="@(noSteps || _currentStepIndex <= -1)">
                    <svg viewBox="0 0 24 24" fill="currentColor">
                        <polygon points="19 4 5 12 19 20 19 4"></polygon>
                    </svg>
                </button>
                <button class="ctrl-btn ctrl-play" title="@(_isAutoPlaying ? "Pause (Space)" : "Play (Space)")" @onclick="ToggleAutoPlay" disabled="@noSteps">
                    @if (_isAutoPlaying)
                    {
                        <svg viewBox="0 0 24 24" fill="currentColor">
                            <rect x="6" y="4" width="4" height="16"></rect>
                            <rect x="14" y="4" width="4" height="16"></rect>
                        </svg>
                    }
                    else
                    {
                        <svg viewBox="0 0 24 24" fill="currentColor">
                            <polygon points="5 3 19 12 5 21 5 3"></polygon>
                        </svg>
                    }
                </button>
                <button class="ctrl-btn" title="Next (→)" @onclick="GoToNext" disabled="@(noSteps || _currentStepIndex >= _steps.Count - 1)">
                    <svg viewBox="0 0 24 24" fill="currentColor">
                        <polygon points="5 4 19 12 5 20 5 4"></polygon>
                    </svg>
                </button>
                <button class="ctrl-btn" title="Last (End)" @onclick="GoToLast" disabled="@(noSteps || _currentStepIndex >= _steps.Count - 1)">
                    <svg viewBox="0 0 24 24" fill="currentColor">
                        <polygon points="5 4 17 12 5 20 5 4"></polygon>
                        <rect x="18" y="4" width="2" height="16" rx="1"></rect>
                    </svg>
                </button>
            </div>
            <span class="tutorial-keyboard-hint">← → Space · Home · End</span>
        </div>



        @* ─── コンテンツ ──────────────────────────────────────────────────────── *@
        @if (_isLoading)
        {
            <div class="tutorial-loading">
                <span class="loading-spinner">⏳</span> Computing...
            </div>
        }
        else if (_selectedAlgorithm == null)
        {
            <div class="tutorial-empty">
                <div class="empty-icon">🎓</div>
                <div class="empty-text">Select an algorithm from the panel on the left.</div>
                <div class="empty-hint">Each algorithm is demonstrated step by step using a fixed array. Some algorithms use a dedicated array suited for the explanation.</div>
            </div>
        }
        else
        {
            @* ─── アルゴリズム説明パネル（モバイルで折りたたみ可能） ──────────────── *@
            <div class="tutorial-description-panel">
                <div class="tdp-header">
                    <div class="tdp-header__left">
                        <div class="desc-name">@_selectedAlgorithm.Name</div>
                        <a href="@GetTryThisAlgorithmUrl()" class="tutorial-try-btn">▶ Try this</a>
                    </div>
                    <div class="tdp-header__right">
                        <div class="desc-meta">
                            <span class="desc-badge">@_selectedAlgorithm.TimeComplexity</span>
                            <span class="desc-badge">@_selectedAlgorithm.Category</span>
                        </div>
                        <button class="tdp-toggle" @onclick="() => _descExpanded = !_descExpanded" title="@(_descExpanded ? "Collapse" : "Expand")">
                            @(_descExpanded ? "▲" : "▼")
                        </button>
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(_selectedAlgorithm.TutorialDescription))
                {
                    <div class="tdp-body @(_descExpanded ? "" : "tdp-body--hidden")">
                        <div class="desc-body">@RenderDescription(_selectedAlgorithm.TutorialDescription)</div>
                    </div>
                }
            </div>

            @if (_steps.Count == 0)
            {
                <div class="tutorial-empty">
                    <div class="empty-text">No recorded operations for this algorithm.</div>
                </div>
            }
            else
            {
                @* ─── ナラティブパネル ────────────────────────────────────────── *@
                <div class="tutorial-narrative-panel">
                    @{
                        var currentPhase = GetCurrentPhase();
                    }
                    @if (!string.IsNullOrEmpty(currentPhase))
                    {
                        <div class="phase-bar">@currentPhase</div>
                    }
                    <div class="narrative-row">
                        <div class="narrative-badge">
                            @if (_currentStepIndex < 0)
                            {
                                <span>Initial State</span>
                            }
                            else
                            {
                                <span>Step @(_currentStepIndex + 1) / @_steps.Count</span>
                            }
                        </div>
                        <div class="narrative-text">@GetCurrentNarrative()</div>
                    </div>
                </div>

                @* ─── 表示切替トグル（ヒープ木・BST・バケット・ネットワーク対応アルゴリズムのみ） ──────────── *@
                @if (HasAlternateView())
                {
                    <div class="tutorial-view-toggle">
                        <button class="toggle-btn @(!_showTreeView && !_showBucketView && !_showNetworkView ? "toggle-btn--active" : "")"
                                @onclick="() => { _showTreeView = false; _showBucketView = false; _showNetworkView = false; }">
                            <svg viewBox="0 0 20 20" fill="currentColor" width="14" height="14"><circle cx="10" cy="10" r="7" /></svg>
                            Marble
                        </button>
                        @if (HasTreeView())
                        {
                            <button class="toggle-btn @(_showTreeView ? "toggle-btn--active" : "")"
                                    @onclick="() => { _showTreeView = true; _showBucketView = false; _showNetworkView = false; }">
                                <svg viewBox="0 0 20 20" fill="currentColor" width="14" height="14"><path d="M10 2 L10 8 M10 8 L4 14 M10 8 L16 14" stroke="currentColor" stroke-width="2" fill="none" /></svg>
                                @GetTreeToggleLabel()
                            </button>
                        }
                        @if (HasBucketView())
                        {
                            <button class="toggle-btn @(_showBucketView ? "toggle-btn--active" : "")"
                                    @onclick="() => { _showBucketView = true; _showTreeView = false; _showNetworkView = false; }">
                                <svg viewBox="0 0 20 20" fill="currentColor" width="14" height="14">
                                    <rect x="2" y="8" width="4" height="10" rx="1" />
                                    <rect x="8" y="5" width="4" height="13" rx="1" />
                                    <rect x="14" y="11" width="4" height="7" rx="1" />
                                </svg>
                                Buckets
                            </button>
                        }
                        @if (HasNetworkView())
                        {
                            <button class="toggle-btn @(_showNetworkView ? "toggle-btn--active" : "")"
                                    @onclick="() => { _showNetworkView = true; _showTreeView = false; _showBucketView = false; }">
                                <svg viewBox="0 0 20 20" fill="currentColor" width="14" height="14">
                                    <line x1="2" y1="6" x2="18" y2="6" stroke="currentColor" stroke-width="1.5" />
                                    <line x1="2" y1="14" x2="18" y2="14" stroke="currentColor" stroke-width="1.5" />
                                    <line x1="10" y1="6" x2="10" y2="14" stroke="currentColor" stroke-width="2" />
                                    <circle cx="10" cy="6" r="2" />
                                    <circle cx="10" cy="14" r="2" />
                                </svg>
                                Network
                            </button>
                        }
                    </div>
                }

                @* ─── ビジュアライゼーションエリア ──────────────────────────────── *@
                <div class="tutorial-marble-area">
                    @if (_showNetworkView && HasNetworkView())
                    {
                        @* Network view: ソーティングネットワーク図（マーブルは表示しない） *@
                        <NetworkDiagramRenderer Snapshot="@GetCurrentNetwork()"
                                                MaxValue="@_maxValue"
                                                StepIndex="@_currentStepIndex"
                                                Label="Sorting Network" />
                    }
                    else if (_showBucketView && HasBucketView())
                    {
                        @* Distribution view: Main Array マーブル + バケット表示（temp buffer は非表示） *@
                        <MarbleRenderer Values="@GetCurrentMainArray()"
                                        HighlightIndices="@GetCurrentHighlightIndices()"
                                        HighlightType="@GetCurrentHighlightType()"
                                        CompareResult="@GetCurrentCompareResult()"
                                        WriteSourceIndex="@GetCurrentWriteSourceIndex()"
                                        WritePreviousValue="@GetCurrentWritePreviousValue()"
                                        MaxValue="@_maxValue"
                                        StepIndex="@_currentStepIndex"
                                        ShellGap="@GetCurrentShellGap()"
                                        Roles="@GetCurrentRoles()"
                                        Label="Main Array" />
                        <DistributionBucketRenderer
                                                    MaxValue="@_maxValue"
                                                    StepIndex="@_currentStepIndex"
                                                    Label="Buckets" />
                    }
                    else if (_showTreeView && HasTreeView())
                    {
                        @if (IsRecursionView())
                        {
                            <RecursionTreeRenderer Snapshot="@GetCurrentRecursion()"
                                                   MaxValue="@_maxValue"
                                                   StepIndex="@_currentStepIndex"
                                                   HorizScale="@GetRecursionHorizScale()"
                                                   Label="Recursion Tree" />
                        }
                        else if (IsBstView())
                        {
                            <BstTreeRenderer Bst="@GetCurrentBst()"
                                             MaxValue="@_maxValue"
                                             StepIndex="@_currentStepIndex"
                                             Label="BST" />
                        }
                        else
                        {
                            <HeapTreeRenderer Values="@GetCurrentMainArray()"
                                              HeapBoundary="@GetCurrentHeapBoundary()"
                                              HighlightIndices="@GetCurrentHighlightIndices()"
                                              HighlightType="@GetCurrentHighlightType()"
                                              MaxValue="@_maxValue"
                                              BranchingFactor="@GetBranchingFactor()"
                                              ReverseBits="@GetCurrentWeakHeapReverseBits()"
                                              StepIndex="@_currentStepIndex"
                                              Label="@GetTreeToggleLabel()" />
                        }
                    }
                    else
                    {
                        <MarbleRenderer Values="@GetCurrentMainArray()"
                                        HighlightIndices="@GetCurrentHighlightIndices()"
                                        HighlightType="@GetCurrentHighlightType()"
                                        CompareResult="@GetCurrentCompareResult()"
                                        WriteSourceIndex="@GetCurrentWriteSourceIndex()"
                                        WritePreviousValue="@GetCurrentWritePreviousValue()"
                                        MaxValue="@_maxValue"
                                        StepIndex="@_currentStepIndex"
                                        ShellGap="@GetCurrentShellGap()"
                                        Roles="@GetCurrentRoles()"
                                        Label="Main Array" />
                    }

                    @if (!_showBucketView && !_showNetworkView)
                    {
                        @foreach (var bufferId in GetCurrentBufferIds())
                        {
                            <MarbleRenderer Values="@GetCurrentBufferArray(bufferId)"
                                            HighlightIndices="@GetCurrentBufferHighlightIndices(bufferId)"
                                            HighlightType="@GetCurrentHighlightType()"
                                            CompareResult="@GetCurrentCompareResult()"
                                            MaxValue="@_maxValue"
                                            StepIndex="@_currentStepIndex"
                                            Label="@($"Buffer {bufferId}")"
                                            IsBuffer="true" />
                        }
                    }
                </div>
            }
        }
    </div>
</div>


@code {
    [Parameter] public string? AlgorithmName { get; set; }

    // ─── デフォルトチュートリアル配列 ──────────────────────────────────────
    private int[] GetTutorialArrayFor(AlgorithmMetadata algo)
        => algo.TutorialArrayType.ToArray();

    // ─── 状態 ──────────────────────────────────────────────────────────────
    private AlgorithmMetadata? _selectedAlgorithm;
    private List<TutorialStep> _steps = [];
    private int _currentStepIndex = -1;  // -1 = 開始状態（操作適用前）
    private bool _isLoading;
    private bool _isAutoPlaying;
    private int _speedIndex = 2;  // default: Normal (500ms)
    private static readonly (string Label, int Ms)[] SpeedSteps =
    [
        ("Fastest", 100),
        ("Fast", 250),
        ("Normal", 500),
        ("Slow", 1000),
        ("Slowest", 2000)
    ];
    private int _autoPlaySpeedMs => SpeedSteps[_speedIndex].Ms;
    private bool _descExpanded = false;

    private int _maxValue = 9;
    private CancellationTokenSource? _autoPlayCts;
    private ElementReference _containerRef;
    private bool _showTreeView = true;  // デフォルトは木表示（ヒープ木対応アルゴリズムのみ）
    private bool _showBucketView = true; // デフォルトはバケット表示（Distribution 対応アルゴリズムのみ）
    private bool _showNetworkView = true; // デフォルトはネットワーク表示（Network 対応アルゴリズムのみ）
    private int _windowWidth = 0; // ウィンドウ幅（0 = 未取得1.0）

    // ─── ナビゲーション ────────────────────────────────────────────────────

    private async Task NavigateToHome()
    {
        await JS.InvokeVoidAsync("history.back");
    }

    // ─── ライフサイクル ────────────────────────────────────────────────────

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrEmpty(AlgorithmName)) return;

        var decoded = Uri.UnescapeDataString(AlgorithmName);
        var algo = GetTutorialAlgorithms()
            .FirstOrDefault(a => string.Equals(a.Name, decoded, StringComparison.OrdinalIgnoreCase));

        if (algo != null && algo != _selectedAlgorithm)
            await LoadAlgorithm(algo);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await _containerRef.FocusAsync();
            _windowWidth = await JS.InvokeAsync<int>("scrollHelper.getWindowWidth");
            StateHasChanged();
        }
    }

    public void Dispose()
    {
        _autoPlayCts?.Cancel();
        _autoPlayCts?.Dispose();
    }

    // タブレット・スマホ向けに RecursionTree の水平間隔を圧縮するスケール係数
    private double GetRecursionHorizScale() => _windowWidth switch
    {
        > 0 and <= 767 => 0.5,
        >= 768 and <= 1279 => 0.65,
        _ => 1.0
    };

    // ─── アルゴリズム選択 ──────────────────────────────────────────────────

    private async Task OnAlgorithmChanged(ChangeEventArgs e)
    {
        var name = e.Value?.ToString();
        if (string.IsNullOrEmpty(name)) return;

        var algo = GetTutorialAlgorithms().FirstOrDefault(a => a.Name == name);
        if (algo != null)
            await LoadAlgorithm(algo);
    }

    private async Task LoadAlgorithm(AlgorithmMetadata algo)
    {
        StopAutoPlay();
        _selectedAlgorithm = algo;
        _steps = [];
        _currentStepIndex = -1;
        _isLoading = true;
        StateHasChanged();

        await Task.Yield();

        try
        {
            var tutorialArray = GetTutorialArrayFor(algo);
            _maxValue = tutorialArray.Length > 0 ? tutorialArray.Max() : 9;
            var (operations, _, _) = await Executor.ExecuteAndRecordAsync(tutorialArray, algo);
            _steps = TutorialStepBuilder.Build(tutorialArray, operations, algo.TutorialVisualizationHint, algo.TutorialLsdRadix);
            _showTreeView = HasTreeView();
            _showBucketView = HasBucketView();
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    // ─── ナビゲーション ────────────────────────────────────────────────────

    private void GoToFirst()
    {
        _currentStepIndex = -1;
        StateHasChanged();
    }

    private void GoToPrevious()
    {
        if (_currentStepIndex > -1)
        {
            _currentStepIndex--;
            StateHasChanged();
        }
    }

    private void GoToNext()
    {
        if (_currentStepIndex < _steps.Count - 1)
        {
            _currentStepIndex++;
            StateHasChanged();
        }
        else if (_isAutoPlaying)
        {
            StopAutoPlay();
        }
    }

    private void GoToLast()
    {
        StopAutoPlay();
        _currentStepIndex = _steps.Count - 1;
        StateHasChanged();
    }

    // ─── 自動再生 ──────────────────────────────────────────────────────────

    private void ToggleAutoPlay()
    {
        if (_isAutoPlaying)
            StopAutoPlay();
        else
            StartAutoPlay();
    }

    private void StartAutoPlay()
    {
        if (_currentStepIndex >= _steps.Count - 1)
            _currentStepIndex = -1;

        _isAutoPlaying = true;
        _autoPlayCts = new CancellationTokenSource();
        _ = RunAutoPlayLoop(_autoPlayCts.Token);
    }

    private void StopAutoPlay()
    {
        _autoPlayCts?.Cancel();
        _autoPlayCts?.Dispose();
        _autoPlayCts = null;
        _isAutoPlaying = false;
    }

    private async Task RunAutoPlayLoop(CancellationToken token)
    {
        try
        {
            while (!token.IsCancellationRequested && _currentStepIndex < _steps.Count - 1)
            {
                await Task.Delay(_autoPlaySpeedMs, token);
                await InvokeAsync(() =>
                {
                    if (_currentStepIndex < _steps.Count - 1)
                        _currentStepIndex++;
                    StateHasChanged();
                });
            }
        }
        catch (OperationCanceledException) { }
        finally
        {
            await InvokeAsync(() =>
            {
                _isAutoPlaying = false;
                StateHasChanged();
            });
        }
    }

    private void OnSpeedChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int val))
            _speedIndex = Math.Clamp(val, 0, SpeedSteps.Length - 1);
    }

    // ─── キーボード ────────────────────────────────────────────────────────

    private void OnKeyDown(KeyboardEventArgs e)
    {
        switch (e.Key)
        {
            case "ArrowLeft":
                GoToPrevious();
                break;
            case "ArrowRight":
                GoToNext();
                break;
            case " ":
                ToggleAutoPlay();
                break;
            case "Home":
                GoToFirst();
                break;
            case "End":
                GoToLast();
                break;
        }
    }

    // ─── 現在ステップのデータ取得 ──────────────────────────────────────────

    private int[] GetCurrentMainArray()
        => _currentStepIndex < 0 ? GetTutorialArrayFor(_selectedAlgorithm!) : _steps[_currentStepIndex].ArraySnapshot;

    private int[] GetCurrentHighlightIndices()
        => _currentStepIndex < 0 ? [] : _steps[_currentStepIndex].HighlightIndices;

    private int[] GetCurrentBufferHighlightIndices(int bufferId)
    {
        if (_currentStepIndex < 0) return [];
        var step = _steps[_currentStepIndex];
        return step.BufferHighlightIndices.TryGetValue(bufferId, out var indices) ? indices : [];
    }

    private OperationType GetCurrentHighlightType()
        => _currentStepIndex < 0 ? OperationType.Compare : _steps[_currentStepIndex].HighlightType;

    private int? GetCurrentCompareResult()
        => _currentStepIndex < 0 ? null : _steps[_currentStepIndex].CompareResult;

    private int? GetCurrentWriteSourceIndex()
        => _currentStepIndex < 0 ? null : _steps[_currentStepIndex].WriteSourceIndex;

    private int? GetCurrentWritePreviousValue()
        => _currentStepIndex < 0 ? null : _steps[_currentStepIndex].WritePreviousValue;

    private int GetCurrentHeapBoundary()
    {
        if (_currentStepIndex < 0)
            return GetTutorialArrayFor(_selectedAlgorithm!).Length;
        return _steps[_currentStepIndex].HeapBoundary ?? GetTutorialArrayFor(_selectedAlgorithm!).Length;
    }

    private bool HasAlternateView()
        => _selectedAlgorithm?.TutorialVisualizationHint != TutorialVisualizationHint.None;

    private bool HasTreeView()
        => _selectedAlgorithm?.TutorialVisualizationHint is
            TutorialVisualizationHint.HeapTree or
            TutorialVisualizationHint.TernaryHeapTree or
            TutorialVisualizationHint.WeakHeapTree or
            TutorialVisualizationHint.BstTree or
            TutorialVisualizationHint.AvlTree or
            TutorialVisualizationHint.RecursionTree;

    private bool HasBucketView()
        => _selectedAlgorithm?.TutorialVisualizationHint is
            TutorialVisualizationHint.ValueBucket or
            TutorialVisualizationHint.DigitBucketLsd or
            TutorialVisualizationHint.DigitBucketMsd;

    private bool HasNetworkView()
        => _selectedAlgorithm?.TutorialVisualizationHint is
            TutorialVisualizationHint.SortingNetwork;

    private bool IsBstView()
        => _selectedAlgorithm?.TutorialVisualizationHint is
            TutorialVisualizationHint.BstTree or
            TutorialVisualizationHint.AvlTree;

    private bool IsRecursionView()
        => _selectedAlgorithm?.TutorialVisualizationHint == TutorialVisualizationHint.RecursionTree;

    private int GetBranchingFactor()
        => _selectedAlgorithm?.TutorialVisualizationHint == TutorialVisualizationHint.TernaryHeapTree ? 3 : 2;

    private string GetTreeToggleLabel()
        => _selectedAlgorithm?.TutorialVisualizationHint switch
        {
            TutorialVisualizationHint.TernaryHeapTree => "Ternary Heap",
            TutorialVisualizationHint.WeakHeapTree    => "Weak Heap",
            TutorialVisualizationHint.BstTree         => "BST",
            TutorialVisualizationHint.AvlTree         => "AVL Tree",
            TutorialVisualizationHint.RecursionTree   => "Recursion Tree",
            _ => "Heap Tree"
        };

    private bool[]? GetCurrentWeakHeapReverseBits()
        => _currentStepIndex < 0 ? null : _steps[_currentStepIndex].WeakHeapReverseBits;

    private BstSnapshot? GetCurrentBst()
        => _currentStepIndex < 0 ? new BstSnapshot { Size = 0, Root = -1 }
            : _steps[_currentStepIndex].Bst;

    private RecursionSnapshot? GetCurrentRecursion()
    {
        if (_currentStepIndex < 0)
            return BuildInitialRecursionSnapshot();
        return _steps[_currentStepIndex].Recursion;
    }

    private DistributionSnapshot? GetCurrentDistribution()
    {
        if (_currentStepIndex < 0)
            return BuildInitialDistributionSnapshot();
        return _steps[_currentStepIndex].Distribution;
    }

    private NetworkSnapshot? GetCurrentNetwork()
    {
        if (_currentStepIndex < 0)
            return BuildInitialNetworkSnapshot();
        return _steps[_currentStepIndex].Network;
    }

    private int? GetCurrentShellGap()
        => _currentStepIndex < 0 ? null : _steps[_currentStepIndex].ShellGap;

    private DistributionSnapshot? BuildInitialDistributionSnapshot()
    {
        if (_selectedAlgorithm == null || !HasBucketView()) return null;
        var arr = GetTutorialArrayFor(_selectedAlgorithm);
        if (arr.Length == 0) return null;

        if (_selectedAlgorithm.TutorialVisualizationHint == TutorialVisualizationHint.DigitBucketLsd)
        {
            int radix = _selectedAlgorithm.TutorialLsdRadix > 0 ? _selectedAlgorithm.TutorialLsdRadix : 10;
            return new DistributionSnapshot
            {
                BucketCount = radix,
                BucketLabels = Enumerable.Range(0, radix).Select(i => i.ToString()).ToArray(),
                Buckets = Enumerable.Range(0, radix).Select(_ => Array.Empty<int>()).ToArray(),
                Phase = DistributionPhase.Scatter,
                ActiveBucketIndex = -1,
                ActiveElementInBucket = -1,
                PassIndex = 0,
                PassLabel = radix == 4 ? "bits 0-1" : "ones digit",
            };
        }

        if (_selectedAlgorithm.TutorialVisualizationHint == TutorialVisualizationHint.DigitBucketMsd)
        {
            int radix = _selectedAlgorithm.TutorialLsdRadix > 0 ? _selectedAlgorithm.TutorialLsdRadix : 10;
            var msdMaxVal = arr.Max();
            int maxDigit;
            if (radix == 4)
            {
                uint key = (uint)msdMaxVal ^ 0x8000_0000u;
                maxDigit = key > 0 ? (32 - System.Numerics.BitOperations.LeadingZeroCount(key) + 1) / 2 : 1;
            }
            else // b=10
            {
                ulong absMax = (ulong)Math.Abs(msdMaxVal);
                maxDigit = absMax > 0 ? (int)Math.Floor(Math.Log10(absMax)) + 1 : 1;
            }
            int digitIndex = maxDigit - 1;
            return new DistributionSnapshot
            {
                BucketCount = radix,
                BucketLabels = Enumerable.Range(0, radix).Select(i => i.ToString()).ToArray(),
                Buckets = Enumerable.Range(0, radix).Select(_ => Array.Empty<int>()).ToArray(),
                Phase = DistributionPhase.Scatter,
                ActiveBucketIndex = -1,
                ActiveElementInBucket = -1,
                PassIndex = 0,
                PassLabel = radix == 4 ? $"bits {digitIndex * 2}-{digitIndex * 2 + 1}" : (digitIndex == 0 ? "ones digit" : digitIndex == 1 ? "tens digit" : $"10^{digitIndex} digit"),
                ActiveRange = (0, arr.Length),
                DigitIndex = digitIndex,
            };
        }

        // ValueBucket (Pigeonhole / Counting / Bucket)
        var minVal = arr.Min();
        var maxVal = arr.Max();
        var bucketCount = maxVal > minVal ? maxVal - minVal + 1 : 1;
        return new DistributionSnapshot
        {
            BucketCount = bucketCount,
            BucketLabels = Enumerable.Range(minVal, bucketCount).Select(v => v.ToString()).ToArray(),
            Buckets = Enumerable.Range(0, bucketCount).Select(_ => Array.Empty<int>()).ToArray(),
            Phase = DistributionPhase.Scatter,
            ActiveBucketIndex = -1,
            ActiveElementInBucket = -1,
        };
    }

    private NetworkSnapshot? BuildInitialNetworkSnapshot()
    {
        if (_selectedAlgorithm == null || !HasNetworkView()) return null;
        var arr = GetTutorialArrayFor(_selectedAlgorithm);
        if (arr.Length == 0) return null;

        // Network structure is pre-calculated by NetworkTracker, so initial state has empty comparators
        // The first step will have the full network structure
        return new NetworkSnapshot
        {
            WireCount = arr.Length,
            Comparators = [],
            ActiveComparatorIndex = -1,
            ComparatorResults = [],
            WireValues = arr,
        };
    }

    private RecursionSnapshot? BuildInitialRecursionSnapshot()
    {
        if (_selectedAlgorithm == null || !IsRecursionView()) return null;
        var arr = GetTutorialArrayFor(_selectedAlgorithm);
        if (arr.Length == 0) return null;

        // Initial state: root node only, pending
        var rootNode = new RecursionNode
        {
            Id = 0,
            ParentId = -1,
            Start = 0,
            End = arr.Length,
            State = RecursionNodeState.Pending,
            Values = arr,
            Depth = 0
        };

        return new RecursionSnapshot
        {
            Nodes = [rootNode],
            ActiveNodeId = -1
        };
    }

    private string GetCurrentNarrative()
        => _currentStepIndex < 0
            ? $"This is the array before sorting. Follow {_selectedAlgorithm?.Name} step by step."
            : _steps[_currentStepIndex].Narrative;

    private string GetCurrentPhase()
        => _currentStepIndex < 0 ? string.Empty : _steps[_currentStepIndex].Phase;

    private Dictionary<int, SortAlgorithm.Contexts.RoleType> GetCurrentRoles()
        => _currentStepIndex < 0 ? [] : _steps[_currentStepIndex].Roles;

    private IEnumerable<int> GetCurrentBufferIds()
    {
        if (_currentStepIndex < 0) return [];
        return _steps[_currentStepIndex].BufferSnapshots.Keys.OrderBy(k => k);
    }

    private int[] GetCurrentBufferArray(int bufferId)
    {
        if (_currentStepIndex < 0) return [];
        var step = _steps[_currentStepIndex];
        return step.BufferSnapshots.TryGetValue(bufferId, out var arr) ? arr : [];
    }

    // ─── アルゴリズムリスト ────────────────────────────────────────────────

    private IEnumerable<AlgorithmMetadata> GetTutorialAlgorithms()
        => AlgorithmRegistry.GetAllAlgorithms()
            .Where(a => !a.ExcludeFromTutorial);

    private IEnumerable<string> GetTutorialCategories()
    {
        var algorithms = GetTutorialAlgorithms();
        var categoryOrder = algorithms
            .Select((a, i) => new { a.Category, i })
            .GroupBy(x => x.Category)
            .ToDictionary(g => g.Key, g => g.Min(x => x.i));

        return algorithms
            .Select(a => a.Category)
            .Distinct()
            .OrderBy(c => categoryOrder[c]);
    }

    private IEnumerable<AlgorithmMetadata> GetAlgorithmsByCategory(string category)
        => GetTutorialAlgorithms()
            .Where(a => a.Category == category);

