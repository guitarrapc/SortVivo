@page "/tutorial"
@page "/tutorial/{AlgorithmName}"
@using SortAlgorithm.VisualizationWeb.Models
@using SortAlgorithm.VisualizationWeb.Services
@using SortAlgorithm.VisualizationWeb.Components
@inject SortExecutor Executor
@inject AlgorithmRegistry AlgorithmRegistry
@inject NavigationManager Navigation
@inject NavigationStateService NavigationState
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>Tutorial | Sorting Playground</PageTitle>

<div class="tutorial-page" @onkeydown="OnKeyDown" tabindex="0" @ref="_containerRef">

<div class="header">
        <div class="tutorial-header__left">
            <button class="tutorial-back-btn" @onclick="NavigateToHome" title="Back to Home">
                <svg viewBox="0 0 24 24" fill="currentColor">
                    <path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z" />
                </svg>
            </button>
        </div>
        <h1 class="tutorial-title">Tutorial</h1>
        <div class="header__actions">
        </div>
    </div>


    @* ─── カードパネル（PC: 左サイドバー / タブレット+スマホ: 再生コントロールバー上段） ─── *@
    <div class="tutorial-cards-panel">
        <fieldset class="controls-fieldset" disabled="@_isLoading">

            @* ── Sort Target ── *@
            <div class="ui-card">
                <span class="ui-card__title">Sort Target</span>
                <div class="qap__item">
                    <span class="stat-label">Algorithm</span>
                    <select value="@(_selectedAlgorithm?.Name ?? "")"
                            @onchange="OnAlgorithmChanged">
                        @foreach (var category in GetTutorialCategories())
                        {
                            <optgroup label="@category">
                                @foreach (var algo in GetAlgorithmsByCategory(category))
                                {
                                    <option value="@algo.Name">@algo.Name</option>
                                }
                            </optgroup>
                        }
                    </select>
                </div>
            </div>

            @* ── Speed ── *@
            <div class="ui-card">
                <span class="ui-card__title">Speed</span>
                <div class="qap__item qap__item--vertical">
                    <div class="qap__slider-header">
                        <span class="stat-label">Interval</span>
                        <span class="stat-value qap__slider-value">@_autoPlaySpeedMs ms</span>
                    </div>
                    <input type="range" min="200" max="2000" step="100"
                           value="@_autoPlaySpeedMs"
                           @oninput="OnSpeedChanged"
                           @onkeydown:stopPropagation
                           style="@RangeTrackStyle(_autoPlaySpeedMs, 200, 2000)" />
                </div>
            </div>

        </fieldset>
    </div>

    @* ─── メインエリア ────────────────────────────────────────────────────── *@
    <div class="tutorial-main-area">
        @{
            bool noSteps = _selectedAlgorithm == null || _steps.Count == 0;
        }

        @* ─── 再生コントロールバー ──────────────────────────────────────── *@
        <div class="tutorial-play-control-bar">
            <div class="ctrl-buttons">
                <button class="ctrl-btn" title="First (Home)" @onclick="GoToFirst" disabled="@(noSteps || _currentStepIndex <= -1)">
                    <svg viewBox="0 0 24 24" fill="currentColor">
                        <rect x="4" y="4" width="2" height="16" rx="1"></rect>
                        <polygon points="19 4 7 12 19 20 19 4"></polygon>
                    </svg>
                </button>
                <button class="ctrl-btn" title="Previous (←)" @onclick="GoToPrevious" disabled="@(noSteps || _currentStepIndex <= -1)">
                    <svg viewBox="0 0 24 24" fill="currentColor">
                        <polygon points="19 4 5 12 19 20 19 4"></polygon>
                    </svg>
                </button>
                <button class="ctrl-btn ctrl-play" title="@(_isAutoPlaying ? "Pause (Space)" : "Play (Space)")" @onclick="ToggleAutoPlay" disabled="@noSteps">
                    @if (_isAutoPlaying)
                    {
                        <svg viewBox="0 0 24 24" fill="currentColor">
                            <rect x="6" y="4" width="4" height="16"></rect>
                            <rect x="14" y="4" width="4" height="16"></rect>
                        </svg>
                    }
                    else
                    {
                        <svg viewBox="0 0 24 24" fill="currentColor">
                            <polygon points="5 3 19 12 5 21 5 3"></polygon>
                        </svg>
                    }
                </button>
                <button class="ctrl-btn" title="Next (→)" @onclick="GoToNext" disabled="@(noSteps || _currentStepIndex >= _steps.Count - 1)">
                    <svg viewBox="0 0 24 24" fill="currentColor">
                        <polygon points="5 4 19 12 5 20 5 4"></polygon>
                    </svg>
                </button>
                <button class="ctrl-btn" title="Last (End)" @onclick="GoToLast" disabled="@(noSteps || _currentStepIndex >= _steps.Count - 1)">
                    <svg viewBox="0 0 24 24" fill="currentColor">
                        <polygon points="5 4 17 12 5 20 5 4"></polygon>
                        <rect x="18" y="4" width="2" height="16" rx="1"></rect>
                    </svg>
                </button>
            </div>
            <span class="tutorial-keyboard-hint">← → Space · Home · End</span>
        </div>



        @* ─── コンテンツ ──────────────────────────────────────────────────────── *@
        @if (_isLoading)
        {
            <div class="tutorial-loading">
                <span class="loading-spinner">⏳</span> Computing...
            </div>
        }
        else if (_selectedAlgorithm == null)
        {
            <div class="tutorial-empty">
                <div class="empty-icon">🎓</div>
                <div class="empty-text">Select an algorithm from the panel on the left.</div>
                <div class="empty-hint">Each algorithm is demonstrated step by step using a fixed array. Some algorithms use a dedicated array suited for the explanation.</div>
            </div>
        }
        else
        {
            @* ─── アルゴリズム説明パネル（モバイルで折りたたみ可能） ──────────────── *@
            <div class="tutorial-description-panel">
                <div class="tdp-header">
                    <div class="tdp-header__left">
                        <div class="desc-name">@_selectedAlgorithm.Name</div>
                        <a href="@GetTryThisAlgorithmUrl()" class="tutorial-try-btn">▶ Try this</a>
                    </div>
                    <div class="tdp-header__right">
                        <div class="desc-meta">
                            <span class="desc-badge">@_selectedAlgorithm.TimeComplexity</span>
                            <span class="desc-badge">@_selectedAlgorithm.Category</span>
                        </div>
                        <button class="tdp-toggle" @onclick="() => _descExpanded = !_descExpanded" title="@(_descExpanded ? "Collapse" : "Expand")">
                            @(_descExpanded ? "▲" : "▼")
                        </button>
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(_selectedAlgorithm.TutorialDescription))
                {
                    <div class="tdp-body @(_descExpanded ? "" : "tdp-body--hidden")">
                        <div class="desc-body">@RenderDescription(_selectedAlgorithm.TutorialDescription)</div>
                    </div>
                }
            </div>

            @if (_steps.Count == 0)
            {
                <div class="tutorial-empty">
                    <div class="empty-text">No recorded operations for this algorithm.</div>
                </div>
            }
            else
            {
                @* ─── ナラティブパネル ────────────────────────────────────────── *@
                <div class="tutorial-narrative-panel">
                    <div class="narrative-badge">
                        @if (_currentStepIndex < 0)
                        {
                            <span>Initial State</span>
                        }
                        else
                        {
                            <span>Step @(_currentStepIndex + 1) / @_steps.Count</span>
                        }
                    </div>
                    <div class="narrative-text">@GetCurrentNarrative()</div>
                </div>

                @* ─── マーブルエリア ──────────────────────────────────────────── *@
                <div class="tutorial-marble-area">
                    <MarbleRenderer Values="@GetCurrentMainArray()"
                                    HighlightIndices="@GetCurrentHighlightIndices()"
                                    HighlightType="@GetCurrentHighlightType()"
                                    MaxValue="@_maxValue"
                                    Label="Main Array" />

                    @foreach (var bufferId in GetCurrentBufferIds())
                    {
                        <MarbleRenderer Values="@GetCurrentBufferArray(bufferId)"
                                        HighlightIndices="@GetCurrentBufferHighlightIndices(bufferId)"
                                        HighlightType="@GetCurrentHighlightType()"
                                        MaxValue="@_maxValue"
                                        Label="@($"Buffer {bufferId}")"
                                        IsBuffer="true" />
                    }
                </div>
            }
        }
    </div>
</div>


@code {
    [Parameter] public string? AlgorithmName { get; set; }

    // ─── デフォルトチュートリアル配列 ──────────────────────────────────────
    private int[] GetTutorialArrayFor(AlgorithmMetadata algo)
        => algo.TutorialArrayType.ToArray();

    // ─── 状態 ──────────────────────────────────────────────────────────────
    private AlgorithmMetadata? _selectedAlgorithm;
    private List<TutorialStep> _steps = [];
    private int _currentStepIndex = -1;  // -1 = 開始状態（操作適用前）
    private bool _isLoading;
    private bool _isAutoPlaying;
    private int _autoPlaySpeedMs = 800;
    private bool _descExpanded = false;

    private int _maxValue = 9;
    private CancellationTokenSource? _autoPlayCts;
    private ElementReference _containerRef;

    // ─── ナビゲーション ────────────────────────────────────────────────────

    private async Task NavigateToHome()
    {
        await JS.InvokeVoidAsync("history.back");
    }

    // ─── ライフサイクル ────────────────────────────────────────────────────

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrEmpty(AlgorithmName)) return;

        var decoded = Uri.UnescapeDataString(AlgorithmName);
        var algo = GetTutorialAlgorithms()
            .FirstOrDefault(a => string.Equals(a.Name, decoded, StringComparison.OrdinalIgnoreCase));

        if (algo != null && algo != _selectedAlgorithm)
            await LoadAlgorithm(algo);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await _containerRef.FocusAsync();
    }

    public void Dispose()
    {
        _autoPlayCts?.Cancel();
        _autoPlayCts?.Dispose();
    }

    // ─── アルゴリズム選択 ──────────────────────────────────────────────────

    private async Task OnAlgorithmChanged(ChangeEventArgs e)
    {
        var name = e.Value?.ToString();
        if (string.IsNullOrEmpty(name)) return;

        var algo = GetTutorialAlgorithms().FirstOrDefault(a => a.Name == name);
        if (algo != null)
            await LoadAlgorithm(algo);
    }

    private async Task LoadAlgorithm(AlgorithmMetadata algo)
    {
        StopAutoPlay();
        _selectedAlgorithm = algo;
        _steps = [];
        _currentStepIndex = -1;
        _isLoading = true;
        StateHasChanged();

        await Task.Yield();

        try
        {
            var tutorialArray = GetTutorialArrayFor(algo);
            _maxValue = tutorialArray.Length > 0 ? tutorialArray.Max() : 9;
            var (operations, _, _) = await Executor.ExecuteAndRecordAsync(tutorialArray, algo);
            _steps = TutorialStepBuilder.Build(tutorialArray, operations);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    // ─── ナビゲーション ────────────────────────────────────────────────────

    private void GoToFirst()
    {
        _currentStepIndex = -1;
        StateHasChanged();
    }

    private void GoToPrevious()
    {
        if (_currentStepIndex > -1)
        {
            _currentStepIndex--;
            StateHasChanged();
        }
    }

    private void GoToNext()
    {
        if (_currentStepIndex < _steps.Count - 1)
        {
            _currentStepIndex++;
            StateHasChanged();
        }
        else if (_isAutoPlaying)
        {
            StopAutoPlay();
        }
    }

    private void GoToLast()
    {
        StopAutoPlay();
        _currentStepIndex = _steps.Count - 1;
        StateHasChanged();
    }

    // ─── 自動再生 ──────────────────────────────────────────────────────────

    private void ToggleAutoPlay()
    {
        if (_isAutoPlaying)
            StopAutoPlay();
        else
            StartAutoPlay();
    }

    private void StartAutoPlay()
    {
        if (_currentStepIndex >= _steps.Count - 1)
            _currentStepIndex = -1;

        _isAutoPlaying = true;
        _autoPlayCts = new CancellationTokenSource();
        _ = RunAutoPlayLoop(_autoPlayCts.Token);
    }

    private void StopAutoPlay()
    {
        _autoPlayCts?.Cancel();
        _autoPlayCts?.Dispose();
        _autoPlayCts = null;
        _isAutoPlaying = false;
    }

    private async Task RunAutoPlayLoop(CancellationToken token)
    {
        try
        {
            while (!token.IsCancellationRequested && _currentStepIndex < _steps.Count - 1)
            {
                await Task.Delay(_autoPlaySpeedMs, token);
                await InvokeAsync(() =>
                {
                    if (_currentStepIndex < _steps.Count - 1)
                        _currentStepIndex++;
                    StateHasChanged();
                });
            }
        }
        catch (OperationCanceledException) { }
        finally
        {
            await InvokeAsync(() =>
            {
                _isAutoPlaying = false;
                StateHasChanged();
            });
        }
    }

    private void OnSpeedChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int val))
            _autoPlaySpeedMs = val;
    }

    // ─── キーボード ────────────────────────────────────────────────────────

    private void OnKeyDown(KeyboardEventArgs e)
    {
        switch (e.Key)
        {
            case "ArrowLeft":
                GoToPrevious();
                break;
            case "ArrowRight":
                GoToNext();
                break;
            case " ":
                ToggleAutoPlay();
                break;
            case "Home":
                GoToFirst();
                break;
            case "End":
                GoToLast();
                break;
        }
    }

    // ─── 現在ステップのデータ取得 ──────────────────────────────────────────

    private int[] GetCurrentMainArray()
        => _currentStepIndex < 0 ? GetTutorialArrayFor(_selectedAlgorithm!) : _steps[_currentStepIndex].ArraySnapshot;

    private int[] GetCurrentHighlightIndices()
        => _currentStepIndex < 0 ? [] : _steps[_currentStepIndex].HighlightIndices;

    private int[] GetCurrentBufferHighlightIndices(int bufferId)
    {
        if (_currentStepIndex < 0) return [];
        var step = _steps[_currentStepIndex];
        return step.BufferHighlightIndices.TryGetValue(bufferId, out var indices) ? indices : [];
    }

    private OperationType GetCurrentHighlightType()
        => _currentStepIndex < 0 ? OperationType.Compare : _steps[_currentStepIndex].HighlightType;

    private string GetCurrentNarrative()
        => _currentStepIndex < 0
            ? $"This is the array before sorting. Follow {_selectedAlgorithm?.Name} step by step."
            : _steps[_currentStepIndex].Narrative;

    private IEnumerable<int> GetCurrentBufferIds()
    {
        if (_currentStepIndex < 0) return [];
        return _steps[_currentStepIndex].BufferSnapshots.Keys.OrderBy(k => k);
    }

    private int[] GetCurrentBufferArray(int bufferId)
    {
        if (_currentStepIndex < 0) return [];
        var step = _steps[_currentStepIndex];
        return step.BufferSnapshots.TryGetValue(bufferId, out var arr) ? arr : [];
    }

    // ─── アルゴリズムリスト ────────────────────────────────────────────────

    private IEnumerable<AlgorithmMetadata> GetTutorialAlgorithms()
        => AlgorithmRegistry.GetAllAlgorithms()
            .Where(a => !a.ExcludeFromTutorial);

    private IEnumerable<string> GetTutorialCategories()
    {
        var algorithms = GetTutorialAlgorithms();
        var categoryOrder = algorithms
            .Select((a, i) => new { a.Category, i })
            .GroupBy(x => x.Category)
            .ToDictionary(g => g.Key, g => g.Min(x => x.i));

        return algorithms
            .Select(a => a.Category)
            .Distinct()
            .OrderBy(c => categoryOrder[c]);
    }

    private IEnumerable<AlgorithmMetadata> GetAlgorithmsByCategory(string category)
        => GetTutorialAlgorithms()
            .Where(a => a.Category == category);

    // ─── 説明テキストのフォーマット ────────────────────────────────────────

    private string GetTryThisAlgorithmUrl()
        => _selectedAlgorithm != null
            ? NavigationState.BuildIndexUrlWithAlgorithm(_selectedAlgorithm.Name)
            : "/";

    private static MarkupString RenderDescription(string? text)
    {
        if (string.IsNullOrWhiteSpace(text)) return new MarkupString(string.Empty);

        var sb = new System.Text.StringBuilder();
        bool inList = false;

        foreach (var rawLine in text.Split('\n'))
        {
            var line = rawLine.TrimEnd();

            if (line.StartsWith("- "))
            {
                if (!inList) { sb.Append("<ul>"); inList = true; }
                var content = line[2..];
                var ci = content.IndexOf(':');
                if (ci > 0)
                {
                    var label = System.Net.WebUtility.HtmlEncode(content[..ci]);
                    var rest = System.Net.WebUtility.HtmlEncode(content[(ci + 1)..]);
                    sb.Append($"<li><strong>{label}:</strong>{rest}</li>");
                }
                else
                {
                    sb.Append($"<li>{System.Net.WebUtility.HtmlEncode(content)}</li>");
                }
            }
            else
            {
                if (inList) { sb.Append("</ul>"); inList = false; }
                if (string.IsNullOrWhiteSpace(line)) continue;

                var ci = line.IndexOf(':');
                if (ci > 0)
                {
                    var label = System.Net.WebUtility.HtmlEncode(line[..ci]);
                    var rest = System.Net.WebUtility.HtmlEncode(line[(ci + 1)..]);
                    sb.Append($"<p><strong>{label}:</strong>{rest}</p>");
                }
                else
                {
                    sb.Append($"<p>{System.Net.WebUtility.HtmlEncode(line)}</p>");
                }
            }
        }

        if (inList) sb.Append("</ul>");
        return new MarkupString(sb.ToString());
    }

    private static string RangeTrackStyle(double value, double min, double max)
    {
        var pct = (value - min) / (max - min) * 100;
        return $"background:linear-gradient(to right,var(--color-accent) 0%,var(--color-accent) {pct:F1}%,#4A4A4A {pct:F1}%,#4A4A4A 100%)";
    }
}
